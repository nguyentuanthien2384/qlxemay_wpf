<Window x:Class="QLXeMay.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Quản lý cửa hàng xe máy"
        Width="1280" Height="800" MinWidth="1120" MinHeight="700"
        WindowStartupLocation="CenterScreen" ResizeMode="CanResize"
        FontFamily="Segoe UI" Background="{StaticResource Surface}">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <Style x:Key="SideNavButton" TargetType="Button">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13.5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource BrandText}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome" CornerRadius="8" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <Grid>
                                <Border x:Name="Bar" Width="3" HorizontalAlignment="Left" Background="#2563EB" CornerRadius="2" Opacity="0" Margin="-10,8"/>
                                <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#334155"/>
                                <Setter TargetName="Bar" Property="Opacity" Value="1"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#475569"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="230"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ===== Sidebar ===== -->
        <Border Grid.Column="0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#1E293B" Offset="0"/>
                    <GradientStop Color="#0F172A" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <DockPanel Margin="14,18">
                <StackPanel DockPanel.Dock="Top">
                    <Button Command="{Binding HomeCommand}" Style="{StaticResource SideNavButton}" Height="Auto" Margin="0,0,0,18" Padding="4,0">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="40" Height="40" CornerRadius="10" Background="#2563EB">
                                <TextBlock Text="🏍" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="MOTO MANAGER" Foreground="White" FontWeight="Bold" FontSize="13"/>
                                <TextBlock Text="Cửa hàng xe máy" Foreground="{StaticResource BrandMuted}" FontSize="11"/>
                            </StackPanel>
                        </StackPanel>
                    </Button>

                    <Border Background="#172033" CornerRadius="10" Padding="12" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="Đang đăng nhập" Foreground="{StaticResource BrandMuted}" FontSize="11"/>
                            <TextBlock Text="{Binding CurrentUserText}" Foreground="White" TextWrapping="Wrap" FontWeight="SemiBold" FontSize="12.5" Margin="0,3,0,0"/>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="NGHIỆP VỤ" Foreground="{StaticResource BrandMuted}" FontSize="10.5" FontWeight="Bold" Margin="6,0,0,8"/>
                    <Button Command="{Binding HomeCommand}" Style="{StaticResource SideNavButton}" Content="🏠   Trang chủ"/>
                    <Button Command="{Binding OpenNhanVienCommand}" Style="{StaticResource SideNavButton}" Content="👤   Nhân viên"/>
                    <Button Command="{Binding OpenKhachHangCommand}" Style="{StaticResource SideNavButton}" Content="👥   Khách hàng"/>
                    <Button Command="{Binding OpenHangHoaCommand}" Style="{StaticResource SideNavButton}" Content="🏍   Xe máy"/>
                    <Button Command="{Binding OpenHoaDonBanCommand}" Style="{StaticResource SideNavButton}" Content="🧾   Bán hàng"/>
                    <Button Command="{Binding OpenHoaDonNhapCommand}" Style="{StaticResource SideNavButton}" Content="📦   Nhập hàng"/>
                    <Button Command="{Binding OpenBaoCaoKQKDCommand}" Style="{StaticResource SideNavButton}" Content="📊   Doanh thu"/>
                </StackPanel>

                <StackPanel DockPanel.Dock="Bottom">
                    <Border Height="1" Background="#334155" Margin="0,0,0,8"/>
                    <Button Content="🛡   Quản trị TK" Command="{Binding OpenUserAdminCommand}" Style="{StaticResource SideNavButton}"/>
                    <Button Content="📜   Nhật ký" Command="{Binding OpenAuditLogCommand}" Style="{StaticResource SideNavButton}"/>
                    <Button Content="↪   Đăng xuất" Command="{Binding LogoutCommand}" Style="{StaticResource SideNavButton}"/>
                    <Button Content="✕   Thoát" Command="{Binding ExitCommand}" Style="{StaticResource SideNavButton}"/>
                </StackPanel>
                <Grid/>
            </DockPanel>
        </Border>

        <!-- ===== Content area ===== -->
        <Grid Grid.Column="1" Background="{StaticResource Surface}">
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Top bar -->
            <Border Grid.Row="0" Background="{StaticResource Card}" BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1">
                <DockPanel LastChildFill="False" Margin="20,0">
                    <Button DockPanel.Dock="Left" Command="{Binding BackCommand}" VerticalAlignment="Center"
                            Visibility="{Binding IsNotHome, Converter={StaticResource BoolToVis}}"
                            Content="← Trang chủ" Height="34" Margin="0,0,14,0"/>
                    <StackPanel DockPanel.Dock="Left" VerticalAlignment="Center">
                        <TextBlock Text="{Binding CurrentTitle}" FontWeight="Bold" FontSize="15"/>
                        <TextBlock Text="Hệ thống quản lý cửa hàng xe máy" Foreground="{StaticResource Muted}" FontSize="11.5"/>
                    </StackPanel>
                    <Border DockPanel.Dock="Right" VerticalAlignment="Center" Background="{StaticResource AccentSoft}" BorderBrush="#BFDBFE" BorderThickness="1" CornerRadius="14" Padding="12,5" Margin="8,0,0,0">
                        <TextBlock Text="{Binding RoleText}" Foreground="{StaticResource AccentPressed}" FontSize="12" FontWeight="SemiBold"/>
                    </Border>
                    <Border DockPanel.Dock="Right" VerticalAlignment="Center" Background="{StaticResource SuccessSoft}" BorderBrush="#A7F3D0" BorderThickness="1" CornerRadius="14" Padding="12,5">
                        <TextBlock Text="● Trực tuyến" Foreground="{StaticResource Success}" FontSize="12" FontWeight="SemiBold"/>
                    </Border>
                </DockPanel>
            </Border>

            <!-- Swappable content region -->
            <ContentControl x:Name="ContentRegion" Grid.Row="1" Content="{Binding CurrentView}"/>
        </Grid>
    </Grid>
</Window>

<Window x:Class="QLXeMay.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Quản lý cửa hàng xe máy - WPF"
        Width="1180" Height="740" MinWidth="1040" MinHeight="660"
        WindowStartupLocation="CenterScreen" ResizeMode="CanResize"
        FontFamily="Segoe UI" Background="#F4F7F5">
    <Window.Resources>
        <SolidColorBrush x:Key="PageBackground" Color="#F4F7F5"/>
        <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="SurfaceAltBrush" Color="#F8FAF8"/>
        <SolidColorBrush x:Key="PrimaryBrush" Color="#0B6B3A"/>
        <SolidColorBrush x:Key="PrimaryDarkBrush" Color="#084F2D"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#D97706"/>
        <SolidColorBrush x:Key="InkBrush" Color="#17211C"/>
        <SolidColorBrush x:Key="MutedBrush" Color="#69756F"/>
        <SolidColorBrush x:Key="LineBrush" Color="#DDE7E1"/>

        <Style x:Key="TopMenuItemStyle" TargetType="{x:Type MenuItem}">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Foreground" Value="{StaticResource InkBrush}"/>
        </Style>

        <Style x:Key="PanelBorderStyle" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="20"/>
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource InkBrush}"/>
        </Style>

        <Style x:Key="SmallTextStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="ActionTileButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="MinHeight" Value="92"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Stretch"/>
            <Setter Property="Background" Value="{StaticResource SurfaceAltBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource InkBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                                <Setter TargetName="Chrome" Property="Background" Value="#F1F8F3"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#E5F1E9"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Chrome" Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Height" Value="38"/>
            <Setter Property="MinWidth" Value="120"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="7"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{StaticResource PrimaryDarkBrush}"/>
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource PrimaryDarkBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#063F24"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource InkBrush}"/>
        </Style>

        <Style x:Key="MiniButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Margin" Value="0,0,8,8"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Background" Value="#F7FAF8"/>
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource InkBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                                <Setter TargetName="Chrome" Property="Background" Value="#EEF7F1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <DockPanel LastChildFill="True">
        <Menu DockPanel.Dock="Top"
              Height="38"
              Padding="6,0"
              Background="#FFFFFF"
              BorderBrush="{StaticResource LineBrush}"
              BorderThickness="0,0,0,1"
              ItemContainerStyle="{StaticResource TopMenuItemStyle}">
            <MenuItem Header="Danh mục">
                <MenuItem Header="Nhân viên" Command="{Binding OpenNhanVienCommand}"/>
                <MenuItem Header="Công việc" Command="{Binding OpenCongViecCommand}"/>
                <Separator/>
                <MenuItem Header="Khách hàng" Command="{Binding OpenKhachHangCommand}"/>
                <MenuItem Header="Nhà cung cấp" Command="{Binding OpenNhaCungCapCommand}"/>
                <Separator/>
                <MenuItem Header="Hàng hóa" Command="{Binding OpenHangHoaCommand}"/>
                <MenuItem Header="Thể loại" Command="{Binding OpenTheLoaiCommand}"/>
                <MenuItem Header="Màu sắc" Command="{Binding OpenMauSacCommand}"/>
                <MenuItem Header="Hãng sản xuất" Command="{Binding OpenHangSXCommand}"/>
                <MenuItem Header="Nước sản xuất" Command="{Binding OpenNuocSXCommand}"/>
                <MenuItem Header="Phanh xe" Command="{Binding OpenPhanhCommand}"/>
                <MenuItem Header="Động cơ" Command="{Binding OpenDongCoCommand}"/>
                <MenuItem Header="Tình trạng" Command="{Binding OpenTinhTrangCommand}"/>
            </MenuItem>
            <MenuItem Header="Hóa đơn">
                <MenuItem Header="Hóa đơn nhập" Command="{Binding OpenHoaDonNhapCommand}"/>
                <MenuItem Header="Đơn đặt hàng / Bán" Command="{Binding OpenHoaDonBanCommand}"/>
            </MenuItem>
            <MenuItem Header="Tìm kiếm">
                <MenuItem Header="Tìm hàng" Command="{Binding OpenTimHangCommand}"/>
                <MenuItem Header="Tìm khách hàng" Command="{Binding OpenTimKhachHangCommand}"/>
                <MenuItem Header="Tìm hóa đơn nhập" Command="{Binding OpenTimHDNCommand}"/>
                <MenuItem Header="Tìm đơn đặt hàng" Command="{Binding OpenTimDDHCommand}"/>
            </MenuItem>
            <MenuItem Header="Báo cáo">
                <MenuItem Header="Báo cáo bán hàng" Command="{Binding OpenBaoCaoBanCommand}"/>
                <MenuItem Header="Báo cáo nhập hàng" Command="{Binding OpenBaoCaoNhapCommand}"/>
                <MenuItem Header="Kết quả kinh doanh" Command="{Binding OpenBaoCaoKQKDCommand}"/>
                <MenuItem Header="Top sản phẩm" Command="{Binding OpenBaoCaoTopCommand}"/>
            </MenuItem>
            <MenuItem Header="Trợ lý AI" FontWeight="SemiBold" Foreground="{StaticResource PrimaryBrush}" Command="{Binding OpenAiCommand}"/>
            <MenuItem Header="{Binding AccountMenuHeader}">
                <MenuItem Header="Quản trị tài khoản" Command="{Binding OpenUserAdminCommand}"/>
                <Separator/>
                <MenuItem Header="Đăng xuất" Command="{Binding LogoutCommand}"/>
            </MenuItem>
            <MenuItem Header="Thoát" Command="{Binding ExitCommand}"/>
        </Menu>

        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="18"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{StaticResource PrimaryBrush}" CornerRadius="8" Padding="24">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="Quản lý cửa hàng bán xe máy"
                                   Foreground="White"
                                   FontSize="30"
                                   FontWeight="Bold"/>
                        <TextBlock Text="Điều phối bán hàng, nhập hàng, danh mục và báo cáo trên một màn hình làm việc."
                                   Foreground="#DCEFE4"
                                   FontSize="14"
                                   Margin="0,8,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="24,0,0,0">
                        <Button Content="Bán hàng" Command="{Binding OpenHoaDonBanCommand}" Style="{StaticResource PrimaryButtonStyle}" Background="#FFFFFF" BorderBrush="#FFFFFF" Foreground="{StaticResource PrimaryBrush}"/>
                        <Button Content="Trợ lý AI" Command="{Binding OpenAiCommand}" Style="{StaticResource PrimaryButtonStyle}" Margin="10,0,0,0" Background="{StaticResource AccentBrush}" BorderBrush="{StaticResource AccentBrush}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2.1*"/>
                    <ColumnDefinition Width="18"/>
                    <ColumnDefinition Width="1.05*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource PanelBorderStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="14"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <DockPanel Grid.Row="0">
                            <StackPanel>
                                <TextBlock Text="Thao tác nhanh" Style="{StaticResource SectionTitleStyle}"/>
                                <TextBlock Text="Mở nhanh các nghiệp vụ dùng thường xuyên trong cửa hàng." Style="{StaticResource SmallTextStyle}" Margin="0,4,0,0"/>
                            </StackPanel>
                        </DockPanel>

                        <UniformGrid Grid.Row="2" Columns="2" Rows="3">
                            <Button Command="{Binding OpenHoaDonBanCommand}" Style="{StaticResource ActionTileButtonStyle}" Margin="0,0,10,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="44"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Width="34" Height="34" CornerRadius="8" Background="#EAF6EE" VerticalAlignment="Top">
                                        <TextBlock Text="&#xE719;" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource PrimaryBrush}" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Lập đơn bán" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource InkBrush}"/>
                                        <TextBlock Text="Tạo đơn đặt hàng, cập nhật khách và tồn kho." Style="{StaticResource SmallTextStyle}" Margin="0,5,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </Button>

                            <Button Command="{Binding OpenHoaDonNhapCommand}" Style="{StaticResource ActionTileButtonStyle}" Margin="10,0,0,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="44"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Width="34" Height="34" CornerRadius="8" Background="#FFF4E6" VerticalAlignment="Top">
                                        <TextBlock Text="&#xE8CB;" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource AccentBrush}" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Nhập hàng" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource InkBrush}"/>
                                        <TextBlock Text="Ghi nhận hóa đơn nhập và bổ sung số lượng xe." Style="{StaticResource SmallTextStyle}" Margin="0,5,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </Button>

                            <Button Command="{Binding OpenHangHoaCommand}" Style="{StaticResource ActionTileButtonStyle}" Margin="0,0,10,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="44"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Width="34" Height="34" CornerRadius="8" Background="#EAF1FF" VerticalAlignment="Top">
                                        <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" Foreground="#2563EB" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Quản lý xe" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource InkBrush}"/>
                                        <TextBlock Text="Danh mục xe, giá nhập, giá bán và thông tin kỹ thuật." Style="{StaticResource SmallTextStyle}" Margin="0,5,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </Button>

                            <Button Command="{Binding OpenTimHangCommand}" Style="{StaticResource ActionTileButtonStyle}" Margin="10,0,0,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="44"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Width="34" Height="34" CornerRadius="8" Background="#F1EEFF" VerticalAlignment="Top">
                                        <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" Foreground="#6D28D9" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Tra cứu" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource InkBrush}"/>
                                        <TextBlock Text="Tìm xe, khách hàng và hóa đơn theo tiêu chí." Style="{StaticResource SmallTextStyle}" Margin="0,5,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </Button>

                            <Button Command="{Binding OpenBaoCaoKQKDCommand}" Style="{StaticResource ActionTileButtonStyle}" Margin="0,0,10,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="44"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Width="34" Height="34" CornerRadius="8" Background="#ECFDF5" VerticalAlignment="Top">
                                        <TextBlock Text="&#xE9D2;" FontFamily="Segoe MDL2 Assets" Foreground="#059669" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Kết quả kinh doanh" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource InkBrush}"/>
                                        <TextBlock Text="Xem doanh thu, chi phí và hiệu quả vận hành." Style="{StaticResource SmallTextStyle}" Margin="0,5,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </Button>

                            <Button Command="{Binding OpenAiCommand}" Style="{StaticResource ActionTileButtonStyle}" Margin="10,0,0,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="44"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Width="34" Height="34" CornerRadius="8" Background="#FFF7ED" VerticalAlignment="Top">
                                        <TextBlock Text="&#xE11B;" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource AccentBrush}" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Trợ lý AI" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource InkBrush}"/>
                                        <TextBlock Text="Hỗ trợ thao tác, gợi ý nghiệp vụ và tìm thông tin." Style="{StaticResource SmallTextStyle}" Margin="0,5,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </Button>
                        </UniformGrid>
                    </Grid>
                </Border>

                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="18"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource PanelBorderStyle}">
                        <StackPanel>
                            <TextBlock Text="Danh mục dữ liệu" Style="{StaticResource SectionTitleStyle}"/>
                            <TextBlock Text="Cập nhật dữ liệu nền cho bán hàng và nhập hàng." Style="{StaticResource SmallTextStyle}" Margin="0,4,0,14"/>
                            <WrapPanel>
                                <Button Content="Nhân viên" Command="{Binding OpenNhanVienCommand}" Style="{StaticResource MiniButtonStyle}"/>
                                <Button Content="Khách hàng" Command="{Binding OpenKhachHangCommand}" Style="{StaticResource MiniButtonStyle}"/>
                                <Button Content="Nhà cung cấp" Command="{Binding OpenNhaCungCapCommand}" Style="{StaticResource MiniButtonStyle}"/>
                                <Button Content="Hàng hóa" Command="{Binding OpenHangHoaCommand}" Style="{StaticResource MiniButtonStyle}"/>
                                <Button Content="Thể loại" Command="{Binding OpenTheLoaiCommand}" Style="{StaticResource MiniButtonStyle}"/>
                                <Button Content="Màu sắc" Command="{Binding OpenMauSacCommand}" Style="{StaticResource MiniButtonStyle}"/>
                                <Button Content="Hãng SX" Command="{Binding OpenHangSXCommand}" Style="{StaticResource MiniButtonStyle}"/>
                                <Button Content="Tình trạng" Command="{Binding OpenTinhTrangCommand}" Style="{StaticResource MiniButtonStyle}"/>
                                <Button Content="Tài khoản" Command="{Binding OpenUserAdminCommand}" Style="{StaticResource MiniButtonStyle}"/>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="2" Style="{StaticResource PanelBorderStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="12"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="12"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <StackPanel>
                                <TextBlock Text="Báo cáo nhanh" Style="{StaticResource SectionTitleStyle}"/>
                                <TextBlock Text="Theo dõi nhập, bán và sản phẩm nổi bật." Style="{StaticResource SmallTextStyle}" Margin="0,4,0,0"/>
                            </StackPanel>

                            <Button Grid.Row="2" Command="{Binding OpenBaoCaoBanCommand}" Style="{StaticResource SecondaryButtonStyle}" HorizontalAlignment="Stretch" Content="Báo cáo bán hàng"/>
                            <Button Grid.Row="4" Command="{Binding OpenBaoCaoNhapCommand}" Style="{StaticResource SecondaryButtonStyle}" HorizontalAlignment="Stretch" Content="Báo cáo nhập hàng"/>

                            <StackPanel Grid.Row="5" VerticalAlignment="Bottom">
                                <Button Command="{Binding OpenBaoCaoTopCommand}" Style="{StaticResource PrimaryButtonStyle}" HorizontalAlignment="Stretch" Content="Top sản phẩm"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>

            <Border Grid.Row="4"
                    Background="#FFFFFF"
                    BorderBrush="{StaticResource LineBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="14,10">
                <DockPanel>
                    <TextBlock Text="Sẵn sàng vận hành"
                               Foreground="{StaticResource PrimaryBrush}"
                               FontWeight="SemiBold"
                               DockPanel.Dock="Left"/>
                    <TextBlock Text="{Binding CurrentUserText}"
                               Foreground="{StaticResource MutedBrush}"
                               HorizontalAlignment="Right"/>
                </DockPanel>
            </Border>
        </Grid>
    </DockPanel>
</Window>

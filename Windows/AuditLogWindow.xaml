<UserControl x:Class="QLXeMay.Windows.AuditLogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Background="{StaticResource Surface}" FontFamily="Segoe UI">
    <UserControl.Resources>
        <Style x:Key="Cmd" TargetType="{x:Type Button}" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Height" Value="34"/>
            <Setter Property="MinWidth" Value="96"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </UserControl.Resources>
    <DockPanel Margin="18">
        <Border DockPanel.Dock="Top" Style="{StaticResource CardBorder}" Padding="10" Margin="0,0,0,12">
            <TextBlock Text="NHẬT KÝ HỆ THỐNG" FontSize="22" FontWeight="Bold" Foreground="{StaticResource Ink}" HorizontalAlignment="Center"/>
        </Border>

        <Border DockPanel.Dock="Top" Style="{StaticResource CardBorder}" Padding="14" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="170"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="170"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Label Grid.Column="0" Content="Từ ngày" FontWeight="SemiBold" Margin="0,0,6,0"/>
                <DatePicker Grid.Column="1" SelectedDate="{Binding FromDate}" Margin="0"/>
                <Label Grid.Column="3" Content="Đến ngày" FontWeight="SemiBold" Margin="0,0,6,0"/>
                <DatePicker Grid.Column="4" SelectedDate="{Binding ToDate}" Margin="0"/>
                <Label Grid.Column="6" Content="Từ khóa" FontWeight="SemiBold" Margin="0,0,6,0"/>
                <TextBox Grid.Column="7" Text="{Binding Keyword, UpdateSourceTrigger=PropertyChanged}" Margin="0"/>
                <Label Grid.Column="9" Content="Số dòng" FontWeight="SemiBold" Margin="0,0,6,0"/>
                <TextBox Grid.Column="10" Text="{Binding MaxRows, UpdateSourceTrigger=PropertyChanged}" Margin="0" MinWidth="90"/>
                <Button Grid.Column="12" Content="Tải dữ liệu" Command="{Binding SearchCommand}" Style="{StaticResource AccentButton}" MinWidth="105" Height="36" Margin="0"/>
            </Grid>
        </Border>

        <Border DockPanel.Dock="Bottom" Style="{StaticResource CardBorder}" Padding="10" Margin="0,12,0,0">
            <DockPanel>
                <TextBlock DockPanel.Dock="Left" Text="{Binding StatusMessage}" VerticalAlignment="Center" Foreground="{StaticResource Ink}"/>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Hôm nay" Command="{Binding TodayCommand}" Style="{StaticResource Cmd}"/>
                    <Button Content="7 ngày gần nhất" Command="{Binding Last7DaysCommand}" Style="{StaticResource Cmd}"/>
                    <Button Content="Xóa bộ lọc" Command="{Binding ClearFilterCommand}" Style="{StaticResource Cmd}"/>
                    <Button Content="Đóng" Command="{Binding CloseCommand}" Style="{StaticResource Cmd}"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="130"/>
            </Grid.RowDefinitions>
            <Border Grid.Row="0" Style="{StaticResource CardBorder}" Padding="10">
                <DataGrid ItemsSource="{Binding Entries}" SelectedItem="{Binding SelectedEntry, Mode=TwoWay}"
                          IsReadOnly="True" AutoGenerateColumns="False" CanUserAddRows="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Thời gian" Binding="{Binding CreatedAtText}" Width="150"/>
                        <DataGridTextColumn Header="Sự kiện" Binding="{Binding EventType}" Width="150"/>
                        <DataGridTextColumn Header="Tài khoản" Binding="{Binding UserText}" Width="150"/>
                        <DataGridTextColumn Header="Chi tiết" Binding="{Binding Detail}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
            <Border Grid.Row="1" Style="{StaticResource CardBorder}" Padding="10" Margin="0,10,0,0">
                <StackPanel>
                    <TextBlock Text="Chi tiết dòng chọn" FontWeight="Bold" Margin="0,0,0,6"/>
                    <TextBox Text="{Binding SelectedEntry.Detail}" IsReadOnly="True" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Height="80"/>
                </StackPanel>
            </Border>
        </Grid>
    </DockPanel>
</UserControl>

<UserControl x:Class="QLXeMay.Windows.AuditLogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Background="{StaticResource Surface}" FontFamily="Segoe UI">
    <UserControl.Resources>
        <Style x:Key="Cmd" TargetType="{x:Type Button}" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Height" Value="34"/>
            <Setter Property="MinWidth" Value="96"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style x:Key="FilterLabel" TargetType="Label" BasedOn="{StaticResource {x:Type Label}}">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="FilterInputText" TargetType="{x:Type TextBox}" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="Height" Value="32"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="Margin" Value="0"/>
        </Style>
    </UserControl.Resources>
    <DockPanel Margin="18">
        <Border DockPanel.Dock="Top" Style="{StaticResource CardBorder}" Padding="10" Margin="0,0,0,12">
            <TextBlock Text="NHẬT KÝ HỆ THỐNG" FontSize="22" FontWeight="Bold" Foreground="{StaticResource Ink}" HorizontalAlignment="Center"/>
        </Border>

        <Border DockPanel.Dock="Top" Style="{StaticResource CardBorder}" Padding="14" Margin="0,0,0,12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <WrapPanel Grid.Row="0" Orientation="Horizontal">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,16,0">
                        <Label Content="Từ ngày" Style="{StaticResource FilterLabel}"/>
                        <DatePicker Style="{StaticResource FormDatePicker}" Width="150" SelectedDate="{Binding FromDate}" Margin="0"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,16,0">
                        <Label Content="Đến ngày" Style="{StaticResource FilterLabel}"/>
                        <DatePicker Style="{StaticResource FormDatePicker}" Width="150" SelectedDate="{Binding ToDate}" Margin="0"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Label Content="Từ khóa" Style="{StaticResource FilterLabel}"/>
                        <TextBox Style="{StaticResource FilterInputText}" Width="200" Text="{Binding Keyword, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                </WrapPanel>

                <WrapPanel Grid.Row="1" Orientation="Horizontal" Margin="0,8,0,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,16,0">
                        <Label Content="Số dòng" Style="{StaticResource FilterLabel}"/>
                        <TextBox Style="{StaticResource FilterInputText}" Width="90" Text="{Binding MaxRows, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <Button Content="Tải dữ liệu" Command="{Binding SearchCommand}" Style="{StaticResource AccentButton}" MinWidth="112" Height="36" Margin="0"/>
                </WrapPanel>
            </Grid>
        </Border>

        <Border DockPanel.Dock="Bottom" Style="{StaticResource CardBorder}" Padding="10" Margin="0,12,0,0">
            <DockPanel>
                <TextBlock DockPanel.Dock="Left" Text="{Binding StatusMessage}" VerticalAlignment="Center" Foreground="{StaticResource Ink}"/>
                <WrapPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Hôm nay" Command="{Binding TodayCommand}" Style="{StaticResource Cmd}"/>
                    <Button Content="7 ngày gần nhất" Command="{Binding Last7DaysCommand}" Style="{StaticResource Cmd}"/>
                    <Button Content="Xóa bộ lọc" Command="{Binding ClearFilterCommand}" Style="{StaticResource Cmd}"/>
                    <Button Content="Đóng" Command="{Binding CloseCommand}" Style="{StaticResource Cmd}"/>
                </WrapPanel>
            </DockPanel>
        </Border>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="170"/>
            </Grid.RowDefinitions>
            <Border Grid.Row="0" Style="{StaticResource CardBorder}" Padding="10">
                <DataGrid ItemsSource="{Binding Entries}" SelectedItem="{Binding SelectedEntry, Mode=TwoWay}"
                          IsReadOnly="True" AutoGenerateColumns="False" CanUserAddRows="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Thời gian" Binding="{Binding CreatedAtText}" Width="150"/>
                        <DataGridTextColumn Header="Sự kiện" Binding="{Binding EventType}" Width="150"/>
                        <DataGridTextColumn Header="Tài khoản" Binding="{Binding UserText}" Width="150"/>
                        <DataGridTextColumn Header="Chi tiết" Binding="{Binding Detail}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
            <Border Grid.Row="1" Style="{StaticResource CardBorder}" Padding="10" Margin="0,10,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Chi tiết dòng chọn" FontWeight="Bold" Margin="0,0,0,6"/>
                    <TextBox Grid.Row="1"
                             Text="{Binding SelectedEntryDetail}"
                             IsReadOnly="True"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             MinHeight="108"/>
                </Grid>
            </Border>
        </Grid>
    </DockPanel>
</UserControl>

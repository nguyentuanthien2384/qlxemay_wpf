<UserControl x:Class="QLXeMay.Windows.ReportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Background="{StaticResource Surface}" FontFamily="Segoe UI">
    <UserControl.Resources>
        <Style x:Key="Cmd" TargetType="{x:Type Button}" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Height" Value="36"/>
            <Setter Property="MinWidth" Value="106"/>
            <Setter Property="Margin" Value="5,0,0,0"/>
        </Style>
        <Style x:Key="FilterLabel" TargetType="Label" BasedOn="{StaticResource {x:Type Label}}">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </UserControl.Resources>
    <DockPanel Margin="18">
        <Border DockPanel.Dock="Top" Style="{StaticResource CardBorder}" Padding="12" Margin="0,0,0,12">
            <TextBlock Text="{Binding WindowTitle}" FontSize="22" FontWeight="Bold" Foreground="{StaticResource Ink}" HorizontalAlignment="Center"/>
        </Border>

        <Border DockPanel.Dock="Top" Style="{StaticResource CardBorder}" Padding="14" Margin="0,0,0,12">
            <WrapPanel Orientation="Horizontal" ItemHeight="40">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,18,0" Visibility="{Binding DateFilterVisibility}">
                    <Label Content="Từ ngày" Style="{StaticResource FilterLabel}"/>
                    <DatePicker Style="{StaticResource FormDatePicker}" Width="150" SelectedDate="{Binding DateFrom}" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,18,0" Visibility="{Binding DateFilterVisibility}">
                    <Label Content="Đến ngày" Style="{StaticResource FilterLabel}"/>
                    <DatePicker Style="{StaticResource FormDatePicker}" Width="150" SelectedDate="{Binding DateTo}" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,18,0" Visibility="{Binding GroupFilterVisibility}">
                    <Label Content="Nhóm theo" Style="{StaticResource FilterLabel}"/>
                    <ComboBox Width="170" ItemsSource="{Binding GroupOptions}" DisplayMemberPath="Name" SelectedItem="{Binding SelectedGroup}" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="Hiển thị" Command="{Binding ShowCommand}" Style="{StaticResource AccentButton}" MinWidth="108" Height="36" Margin="0"/>
                    <Button Content="Xuất Excel" Command="{Binding ExportCommand}" Style="{StaticResource Cmd}"/>
                    <Button Content="Đóng" Command="{Binding CloseCommand}" Style="{StaticResource Cmd}"/>
                </StackPanel>
            </WrapPanel>
        </Border>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="170"/>
            </Grid.RowDefinitions>
            <Border Grid.Row="0" Style="{StaticResource CardBorder}" Padding="12" Margin="0,0,0,10">
                <TextBlock Text="{Binding SummaryText}" FontSize="15" FontWeight="SemiBold" TextWrapping="Wrap"/>
            </Border>
            <Border Grid.Row="1" Style="{StaticResource CardBorder}" Padding="10">
                <DataGrid ItemsSource="{Binding MainView}"
                          IsReadOnly="True"
                          AutoGenerateColumns="True"
                          AutoGeneratingColumn="ReportGrid_AutoGeneratingColumn"
                          CanUserAddRows="False"/>
            </Border>
            <GroupBox Grid.Row="2" Header="Tổng hợp" Margin="0,10,0,0">
                <DataGrid ItemsSource="{Binding SummaryView}"
                          IsReadOnly="True"
                          AutoGenerateColumns="True"
                          AutoGeneratingColumn="ReportGrid_AutoGeneratingColumn"
                          CanUserAddRows="False"/>
            </GroupBox>
        </Grid>
    </DockPanel>
</UserControl>

<UserControl x:Class="QLXeMay.Windows.ReportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Background="{StaticResource Surface}" FontFamily="Segoe UI">
    <UserControl.Resources>
        <Style x:Key="Cmd" TargetType="{x:Type Button}" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Height" Value="36"/>
            <Setter Property="MinWidth" Value="106"/>
            <Setter Property="Margin" Value="5,0,0,0"/>
        </Style>
        <Style x:Key="FilterLabel" TargetType="Label" BasedOn="{StaticResource {x:Type Label}}">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </UserControl.Resources>
    <DockPanel Margin="18">
        <Border DockPanel.Dock="Top" Style="{StaticResource CardBorder}" Padding="12" Margin="0,0,0,12">
            <TextBlock Text="{Binding WindowTitle}" FontSize="22" FontWeight="Bold" Foreground="{StaticResource Ink}" HorizontalAlignment="Center"/>
        </Border>

        <Border DockPanel.Dock="Top" Style="{StaticResource CardBorder}" Padding="14" Margin="0,0,0,12">
            <Grid HorizontalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="170"/>
                    <ColumnDefinition Width="18"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="170"/>
                    <ColumnDefinition Width="18"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="190"/>
                    <ColumnDefinition Width="22"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Label Grid.Column="0" Content="Từ ngày" Style="{StaticResource FilterLabel}" Visibility="{Binding DateFilterVisibility}"/>
                <DatePicker Grid.Column="1" SelectedDate="{Binding DateFrom}" Visibility="{Binding DateFilterVisibility}" Margin="0"/>
                <Label Grid.Column="3" Content="Đến ngày" Style="{StaticResource FilterLabel}" Visibility="{Binding DateFilterVisibility}"/>
                <DatePicker Grid.Column="4" SelectedDate="{Binding DateTo}" Visibility="{Binding DateFilterVisibility}" Margin="0"/>
                <Label Grid.Column="6" Content="Nhóm theo" Style="{StaticResource FilterLabel}" Visibility="{Binding GroupFilterVisibility}"/>
                <ComboBox Grid.Column="7" ItemsSource="{Binding GroupOptions}" DisplayMemberPath="Name" SelectedItem="{Binding SelectedGroup}" Visibility="{Binding GroupFilterVisibility}" Margin="0"/>
                <Button Grid.Column="9" Content="Hiển thị" Command="{Binding ShowCommand}" Style="{StaticResource AccentButton}" MinWidth="108" Height="36" Margin="0"/>
                <Button Grid.Column="10" Content="Xuất Excel" Command="{Binding ExportCommand}" Style="{StaticResource Cmd}"/>
                <Button Grid.Column="11" Content="Đóng" Command="{Binding CloseCommand}" Style="{StaticResource Cmd}"/>
            </Grid>
        </Border>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="170"/>
            </Grid.RowDefinitions>
            <Border Grid.Row="0" Style="{StaticResource CardBorder}" Padding="12" Margin="0,0,0,10">
                <TextBlock Text="{Binding SummaryText}" FontSize="15" FontWeight="SemiBold" TextWrapping="Wrap"/>
            </Border>
            <Border Grid.Row="1" Style="{StaticResource CardBorder}" Padding="10">
                <DataGrid ItemsSource="{Binding MainView}"
                          IsReadOnly="True"
                          AutoGenerateColumns="True"
                          AutoGeneratingColumn="ReportGrid_AutoGeneratingColumn"
                          CanUserAddRows="False"/>
            </Border>
            <GroupBox Grid.Row="2" Header="Tổng hợp" Margin="0,10,0,0">
                <DataGrid ItemsSource="{Binding SummaryView}"
                          IsReadOnly="True"
                          AutoGenerateColumns="True"
                          AutoGeneratingColumn="ReportGrid_AutoGeneratingColumn"
                          CanUserAddRows="False"/>
            </GroupBox>
        </Grid>
    </DockPanel>
</UserControl>

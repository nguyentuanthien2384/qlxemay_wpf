<Window x:Class="QLXeMay.Windows.HoaDonNhapWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Hóa đơn nhập hàng" Height="700" Width="940" WindowStartupLocation="CenterOwner" Background="White">
    <DockPanel Margin="12">
        <TextBlock DockPanel.Dock="Top" Text="HÓA ĐƠN NHẬP HÀNG" FontSize="22" FontWeight="Bold" Foreground="DarkGreen" HorizontalAlignment="Center" Margin="0,0,0,10"/>
        <StackPanel DockPanel.Dock="Bottom" Orientation="Vertical" Margin="0,8,0,0">
            <StackPanel Orientation="Horizontal">
                <Label Content="Tổng tiền:" FontWeight="Bold"/>
                <TextBlock Text="{Binding Total}" Margin="4" FontWeight="Bold" VerticalAlignment="Center"/>
                <Label Content="Bằng chữ:" Margin="24,0,0,0"/>
                <TextBlock Text="{Binding AmountInWords}" Margin="4" FontStyle="Italic" Foreground="Blue" VerticalAlignment="Center"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="Thêm hóa đơn" Command="{Binding NewInvoiceCommand}"/>
                <Button Content="Lưu mặt hàng" Command="{Binding SaveLineCommand}"/>
                <Button Content="Xóa dòng" Command="{Binding DeleteLineCommand}"/>
                <Button Content="Bỏ qua" Command="{Binding ResetCommand}"/>
                <Button Content="Hủy hóa đơn" Command="{Binding CancelInvoiceCommand}"/>
                <Button Content="Xuất Excel" Command="{Binding ExportCommand}"/>
                <Button Content="Đóng" Command="{Binding CloseCommand}"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,6,0,0">
                <Label Content="Mã hóa đơn:"/>
                <ComboBox Width="210" ItemsSource="{Binding InvoiceNumbers}" SelectedValuePath="sohdn" DisplayMemberPath="sohdn"
                          SelectedValue="{Binding SelectedSearchInvoiceNo, Mode=TwoWay}"/>
                <Button Content="Tìm kiếm" Command="{Binding SearchInvoiceCommand}"/>
            </StackPanel>
        </StackPanel>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <GroupBox Header="Thông tin chung" Grid.Row="0" Margin="0,0,0,6">
                <UniformGrid Columns="4" Margin="8">
                    <StackPanel><Label Content="Mã hóa đơn nhập"/><TextBox Text="{Binding InvoiceNo, Mode=OneWay}" IsReadOnly="True"/></StackPanel>
                    <StackPanel><Label Content="Ngày nhập"/><DatePicker SelectedDate="{Binding InvoiceDate}" IsEnabled="{Binding IsInvoiceActive}"/></StackPanel>
                    <StackPanel><Label Content="Mã nhân viên"/><ComboBox ItemsSource="{Binding Employees}" SelectedValuePath="manv" DisplayMemberPath="manv" SelectedValue="{Binding SelectedEmployeeId, Mode=TwoWay}" IsEnabled="{Binding IsInvoiceActive}"/></StackPanel>
                    <StackPanel><Label Content="Tên nhân viên"/><TextBox Text="{Binding EmployeeName, Mode=OneWay}" IsReadOnly="True"/></StackPanel>
                    <StackPanel><Label Content="Mã NCC"/><ComboBox ItemsSource="{Binding Suppliers}" SelectedValuePath="mancc" DisplayMemberPath="mancc" SelectedValue="{Binding SelectedSupplierId, Mode=TwoWay}" IsEnabled="{Binding IsInvoiceActive}"/></StackPanel>
                    <StackPanel><Label Content="Tên NCC"/><TextBox Text="{Binding SupplierName, Mode=OneWay}" IsReadOnly="True"/></StackPanel>
                    <StackPanel><Label Content="Địa chỉ"/><TextBox Text="{Binding SupplierAddress, Mode=OneWay}" IsReadOnly="True"/></StackPanel>
                    <StackPanel><Label Content="Điện thoại"/><TextBox Text="{Binding SupplierPhone, Mode=OneWay}" IsReadOnly="True"/></StackPanel>
                </UniformGrid>
            </GroupBox>

            <GroupBox Header="Thông tin mặt hàng" Grid.Row="1" Margin="0,0,0,6">
                <UniformGrid Columns="6" Margin="8">
                    <StackPanel><Label Content="Mã hàng"/><ComboBox ItemsSource="{Binding Products}" SelectedValuePath="mahang" DisplayMemberPath="mahang" SelectedValue="{Binding SelectedProductId, Mode=TwoWay}" IsEnabled="{Binding IsInvoiceActive}"/></StackPanel>
                    <StackPanel><Label Content="Tên hàng"/><TextBox Text="{Binding ProductName, Mode=OneWay}" IsReadOnly="True"/></StackPanel>
                    <StackPanel><Label Content="Số lượng"/><TextBox Text="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding IsInvoiceActive}"/></StackPanel>
                    <StackPanel><Label Content="Đơn giá nhập"/><TextBox Text="{Binding UnitPrice, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding IsInvoiceActive}"/></StackPanel>
                    <StackPanel><Label Content="Giảm giá (%)"/><TextBox Text="{Binding Discount, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding IsInvoiceActive}"/></StackPanel>
                    <StackPanel><Label Content="Thành tiền"/><TextBox Text="{Binding LineTotal, Mode=OneWay}" IsReadOnly="True"/></StackPanel>
                </UniformGrid>
            </GroupBox>

            <DataGrid Grid.Row="2" ItemsSource="{Binding DetailsView}" SelectedItem="{Binding SelectedDetail, Mode=TwoWay}"
                      IsReadOnly="True" AutoGenerateColumns="True" CanUserAddRows="False"/>
        </Grid>
    </DockPanel>
</Window>

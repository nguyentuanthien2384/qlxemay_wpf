<UserControl x:Class="QLXeMay.Windows.HoaDonNhapWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Background="{StaticResource Surface}" FontFamily="Segoe UI">
    <UserControl.Resources>
        <Style x:Key="Cmd" TargetType="{x:Type Button}" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Height" Value="36"/>
            <Setter Property="MinWidth" Value="104"/>
            <Setter Property="Margin" Value="5"/>
        </Style>
        <Style x:Key="FormField" TargetType="StackPanel">
            <Setter Property="Margin" Value="6,4,6,8"/>
        </Style>
    </UserControl.Resources>
    <DockPanel Margin="18">
        <Border DockPanel.Dock="Top" Style="{StaticResource CardBorder}" Padding="12" Margin="0,0,0,12">
            <TextBlock Text="HÓA ĐƠN NHẬP HÀNG" FontSize="22" FontWeight="Bold" Foreground="{StaticResource Ink}" HorizontalAlignment="Center"/>
        </Border>

        <Border DockPanel.Dock="Bottom" Style="{StaticResource CardBorder}" Padding="10" Margin="0,12,0,0">
            <StackPanel>
                <WrapPanel>
                    <Label Content="Tổng tiền:" FontWeight="Bold"/>
                    <TextBlock Text="{Binding Total}" Margin="4" FontWeight="Bold" VerticalAlignment="Center"/>
                    <Label Content="Bằng chữ:" Margin="24,0,0,0"/>
                    <TextBlock Text="{Binding AmountInWords}" Margin="4" FontStyle="Italic" Foreground="{StaticResource AccentPressed}" VerticalAlignment="Center"/>
                </WrapPanel>
                <WrapPanel HorizontalAlignment="Center" Margin="0,6,0,0">
                    <Button Content="Thêm hóa đơn" Command="{Binding NewInvoiceCommand}" Style="{StaticResource AccentButton}" MinWidth="124" Height="36"/>
                    <Button Content="Lưu dòng hàng" Command="{Binding SaveLineCommand}" Style="{StaticResource Cmd}" MinWidth="118"/>
                    <Button Content="Xóa dòng" Command="{Binding DeleteLineCommand}" Style="{StaticResource Cmd}"/>
                    <Button Content="Bỏ qua" Command="{Binding ResetCommand}" Style="{StaticResource Cmd}"/>
                    <Button Content="Hủy hóa đơn" Command="{Binding CancelInvoiceCommand}" Style="{StaticResource Cmd}" MinWidth="112"/>
                    <Button Content="Xuất Excel" Command="{Binding ExportCommand}" Style="{StaticResource Cmd}"/>
                    <Button Content="Đóng" Command="{Binding CloseCommand}" Style="{StaticResource Cmd}"/>
                </WrapPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,6,0,0">
                    <Label Content="Mã hóa đơn nhập:" FontWeight="SemiBold"/>
                    <ComboBox Width="220" ItemsSource="{Binding InvoiceNumbers}" SelectedValuePath="sohdn" DisplayMemberPath="sohdn" SelectedValue="{Binding SelectedSearchInvoiceNo, Mode=TwoWay}"/>
                    <Button Content="Tìm kiếm" Command="{Binding SearchInvoiceCommand}" Style="{StaticResource Cmd}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <GroupBox Header="Thông tin chung" Grid.Row="0">
                <UniformGrid Columns="4" Margin="8">
                    <StackPanel Style="{StaticResource FormField}"><Label Content="Mã hóa đơn nhập"/><TextBox Text="{Binding InvoiceNo, Mode=OneWay}" IsReadOnly="True"/></StackPanel>
                    <StackPanel Style="{StaticResource FormField}"><Label Content="Ngày nhập"/><DatePicker SelectedDate="{Binding InvoiceDate}" IsEnabled="{Binding IsInvoiceActive}"/></StackPanel>
                    <StackPanel Style="{StaticResource FormField}"><Label Content="Mã nhân viên"/><ComboBox ItemsSource="{Binding Employees}" SelectedValuePath="manv" DisplayMemberPath="manv" SelectedValue="{Binding SelectedEmployeeId, Mode=TwoWay}" IsEnabled="{Binding IsInvoiceActive}"/></StackPanel>
                    <StackPanel Style="{StaticResource FormField}"><Label Content="Tên nhân viên"/><TextBox Text="{Binding EmployeeName, Mode=OneWay}" IsReadOnly="True"/></StackPanel>
                    <StackPanel Style="{StaticResource FormField}"><Label Content="Mã nhà cung cấp"/><ComboBox ItemsSource="{Binding Suppliers}" SelectedValuePath="mancc" DisplayMemberPath="mancc" SelectedValue="{Binding SelectedSupplierId, Mode=TwoWay}" IsEnabled="{Binding IsInvoiceActive}"/></StackPanel>
                    <StackPanel Style="{StaticResource FormField}"><Label Content="Tên nhà cung cấp"/><TextBox Text="{Binding SupplierName, Mode=OneWay}" IsReadOnly="True"/></StackPanel>
                    <StackPanel Style="{StaticResource FormField}"><Label Content="Địa chỉ"/><TextBox Text="{Binding SupplierAddress, Mode=OneWay}" IsReadOnly="True"/></StackPanel>
                    <StackPanel Style="{StaticResource FormField}"><Label Content="Số điện thoại"/><TextBox Text="{Binding SupplierPhone, Mode=OneWay}" IsReadOnly="True"/></StackPanel>
                </UniformGrid>
            </GroupBox>
            <GroupBox Header="Thông tin xe nhập" Grid.Row="1">
                <UniformGrid Columns="6" Margin="8">
                    <StackPanel Style="{StaticResource FormField}"><Label Content="Mã xe"/><ComboBox ItemsSource="{Binding Products}" SelectedValuePath="mahang" DisplayMemberPath="mahang" SelectedValue="{Binding SelectedProductId, Mode=TwoWay}" IsEnabled="{Binding IsInvoiceActive}"/></StackPanel>
                    <StackPanel Style="{StaticResource FormField}"><Label Content="Tên xe"/><TextBox Text="{Binding ProductName, Mode=OneWay}" IsReadOnly="True"/></StackPanel>
                    <StackPanel Style="{StaticResource FormField}"><Label Content="Số lượng"/><TextBox Text="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding IsInvoiceActive}"/></StackPanel>
                    <StackPanel Style="{StaticResource FormField}"><Label Content="Đơn giá nhập"/><TextBox Text="{Binding UnitPrice, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding IsInvoiceActive}"/></StackPanel>
                    <StackPanel Style="{StaticResource FormField}"><Label Content="Giảm giá (%)"/><TextBox Text="{Binding Discount, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding IsInvoiceActive}"/></StackPanel>
                    <StackPanel Style="{StaticResource FormField}"><Label Content="Thành tiền"/><TextBox Text="{Binding LineTotal, Mode=OneWay}" IsReadOnly="True"/></StackPanel>
                </UniformGrid>
            </GroupBox>
            <Border Grid.Row="2" Style="{StaticResource CardBorder}" Padding="10">
                <DataGrid ItemsSource="{Binding DetailsView}"
                          SelectedItem="{Binding SelectedDetail, Mode=TwoWay}"
                          IsReadOnly="True"
                          AutoGenerateColumns="True"
                          AutoGeneratingColumn="DetailsGrid_AutoGeneratingColumn"
                          CanUserAddRows="False"/>
            </Border>
        </Grid>
    </DockPanel>
</UserControl>

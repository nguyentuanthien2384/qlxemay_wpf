<Window x:Class="QLXeMay.Windows.StorefrontWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cửa hàng xe máy - Mua sắm trực tuyến"
        Width="1180" Height="760" MinWidth="1024" MinHeight="640"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI"
        Background="{StaticResource Surface}">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <DockPanel>
        <!-- ===== Top bar ===== -->
        <Border DockPanel.Dock="Top" Background="{StaticResource Card}" BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1" Padding="24,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Width="46" Height="46" CornerRadius="12" VerticalAlignment="Center">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#6366F1" Offset="0"/>
                            <GradientStop Color="#2563EB" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <TextBlock Text="🏍" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <StackPanel Grid.Column="1" Margin="14,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Greeting}" FontSize="18" FontWeight="Bold" Foreground="{StaticResource Ink}"/>
                    <TextBlock Text="{Binding CustomerContact}" FontSize="12" Foreground="{StaticResource Muted}"/>
                </StackPanel>

                <Button Grid.Column="2" Content="Đăng xuất" Command="{Binding LogoutCommand}"
                        Style="{StaticResource GhostButton}" Height="38" Padding="16,0" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <TabControl Margin="0" BorderThickness="0" Background="{StaticResource Surface}">
            <!-- ============ SHOPPING TAB ============ -->
            <TabItem Header="Mua sắm">
                <Grid Margin="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="380"/>
                    </Grid.ColumnDefinitions>

                    <!-- Catalog -->
                    <DockPanel Grid.Column="0" Margin="0,0,16,0">
                        <Border DockPanel.Dock="Top" Background="{StaticResource Card}" BorderBrush="{StaticResource Border}"
                                BorderThickness="1" CornerRadius="10" Padding="12" Margin="0,0,0,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Height="38" VerticalContentAlignment="Center"
                                         Text="{Binding SearchKeyword, UpdateSourceTrigger=PropertyChanged}"
                                         Tag="Tìm theo tên xe, hãng, dòng xe...">
                                    <TextBox.InputBindings>
                                        <KeyBinding Key="Enter" Command="{Binding SearchCommand}"/>
                                    </TextBox.InputBindings>
                                </TextBox>
                                <Button Grid.Column="1" Content="Tìm" Command="{Binding SearchCommand}"
                                        Style="{StaticResource AccentButton}" Height="38" Padding="20,0" Margin="8,0,0,0"/>
                                <Button Grid.Column="2" Content="Tất cả" Command="{Binding RefreshCommand}"
                                        Style="{StaticResource GhostButton}" Height="38" Padding="14,0" Margin="8,0,0,0"/>
                            </Grid>
                        </Border>

                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding Products}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Width="248" Margin="0,0,12,12" Background="{StaticResource Card}"
                                                BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="12" Padding="14">
                                            <StackPanel>
                                                <Border Height="96" CornerRadius="8" Background="{StaticResource AccentSoft}">
                                                    <TextBlock Text="🏍" FontSize="44" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="14"
                                                           Foreground="{StaticResource Ink}" TextWrapping="Wrap" Margin="0,10,0,0" Height="38"/>
                                                <TextBlock Text="{Binding Specs}" FontSize="11" Foreground="{StaticResource Muted}"
                                                           TextWrapping="Wrap" Height="30"/>
                                                <TextBlock Text="{Binding PriceText}" FontWeight="Bold" FontSize="16"
                                                           Foreground="{StaticResource Accent}" Margin="0,6,0,0"/>
                                                <TextBlock Text="{Binding StockText}" FontSize="11" Foreground="{StaticResource Muted}" Margin="0,2,0,8"/>
                                                <Button Content="Thêm vào giỏ"
                                                        Command="{Binding DataContext.AddToCartCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}"
                                                        Style="{StaticResource AccentButton}" Height="36"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DockPanel>

                    <!-- Cart -->
                    <Border Grid.Column="1" Background="{StaticResource Card}" BorderBrush="{StaticResource Border}"
                            BorderThickness="1" CornerRadius="12" Padding="16">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Top">
                                <TextBlock Text="🛒 Giỏ hàng" FontSize="18" FontWeight="Bold" Foreground="{StaticResource Ink}"/>
                                <TextBlock Text="{Binding CartSummaryText}" FontSize="12" Foreground="{StaticResource Muted}" Margin="0,2,0,10"/>
                                <Border Height="1" Background="{StaticResource Border}" Margin="0,0,0,8"/>
                            </StackPanel>

                            <!-- Footer (checkout) -->
                            <StackPanel DockPanel.Dock="Bottom">
                                <Border Height="1" Background="{StaticResource Border}" Margin="0,8"/>
                                <Grid Margin="0,0,0,10">
                                    <TextBlock Text="Tổng cộng" FontSize="14" Foreground="{StaticResource Muted}" HorizontalAlignment="Left"/>
                                    <TextBlock Text="{Binding CartTotalText}" FontSize="20" FontWeight="Bold"
                                               Foreground="{StaticResource Accent}" HorizontalAlignment="Right"/>
                                </Grid>
                                <Button Content="Đặt hàng" Command="{Binding CheckoutCommand}"
                                        Style="{StaticResource AccentButton}" Height="46" FontSize="15"/>
                                <Button Content="Xóa giỏ hàng" Command="{Binding ClearCartCommand}"
                                        Style="{StaticResource GhostButton}" Height="36" Margin="0,8,0,0"/>
                            </StackPanel>

                            <Grid>
                                <TextBlock Text="Chưa có sản phẩm nào trong giỏ.&#x0a;Hãy chọn xe từ danh sách bên trái."
                                           Foreground="{StaticResource Muted}" TextWrapping="Wrap" TextAlignment="Center"
                                           VerticalAlignment="Center" FontSize="13"
                                           Visibility="{Binding IsCartEmpty, Converter={StaticResource BoolToVis}}"/>
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding Cart}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="{StaticResource Surface}" BorderBrush="{StaticResource Border}"
                                                        BorderThickness="1" CornerRadius="8" Padding="10" Margin="0,0,0,8">
                                                    <StackPanel>
                                                        <Grid>
                                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13"
                                                                       Foreground="{StaticResource Ink}" TextWrapping="Wrap"
                                                                       HorizontalAlignment="Left" Width="240"/>
                                                            <Button Content="✕" HorizontalAlignment="Right" VerticalAlignment="Top"
                                                                    Width="24" Height="24" Padding="0" FontSize="11"
                                                                    Command="{Binding DataContext.RemoveCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                    CommandParameter="{Binding}"/>
                                                        </Grid>
                                                        <TextBlock Text="{Binding UnitPriceText}" FontSize="11" Foreground="{StaticResource Muted}"/>
                                                        <Grid Margin="0,8,0,0">
                                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                                                <Button Content="−" Width="28" Height="28" Padding="0" FontSize="15"
                                                                        Command="{Binding DataContext.DecreaseCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                        CommandParameter="{Binding}"/>
                                                                <Border Width="40" Height="28" Background="{StaticResource Card}"
                                                                        BorderBrush="{StaticResource Border}" BorderThickness="1" Margin="4,0">
                                                                    <TextBlock Text="{Binding Quantity}" HorizontalAlignment="Center"
                                                                               VerticalAlignment="Center" FontWeight="SemiBold"/>
                                                                </Border>
                                                                <Button Content="+" Width="28" Height="28" Padding="0" FontSize="15"
                                                                        Command="{Binding DataContext.IncreaseCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                        CommandParameter="{Binding}"/>
                                                            </StackPanel>
                                                            <TextBlock Text="{Binding LineTotalText}" FontWeight="Bold" FontSize="13"
                                                                       Foreground="{StaticResource Ink}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                                        </Grid>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Grid>
                        </DockPanel>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ============ ORDER HISTORY TAB ============ -->
            <TabItem Header="Đơn hàng của tôi">
                <Grid Margin="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="380"/>
                    </Grid.ColumnDefinitions>

                    <DockPanel Grid.Column="0" Margin="0,0,16,0">
                        <Button DockPanel.Dock="Top" Content="Làm mới" Command="{Binding RefreshOrdersCommand}"
                                Style="{StaticResource GhostButton}" Height="36" HorizontalAlignment="Left"
                                Padding="18,0" Margin="0,0,0,10"/>
                        <DataGrid ItemsSource="{Binding Orders}" SelectedItem="{Binding SelectedOrder}"
                                  AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column"
                                  CanUserAddRows="False" GridLinesVisibility="Horizontal">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Mã đơn" Binding="{Binding InvoiceNo}" Width="*"/>
                                <DataGridTextColumn Header="Ngày đặt" Binding="{Binding OrderDate}" Width="110"/>
                                <DataGridTextColumn Header="Số lượng" Binding="{Binding ItemCount}" Width="80"/>
                                <DataGridTextColumn Header="Tổng tiền" Binding="{Binding TotalText}" Width="130"/>
                                <DataGridTextColumn Header="Đặt cọc" Binding="{Binding DepositText}" Width="130"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>

                    <Border Grid.Column="1" Background="{StaticResource Card}" BorderBrush="{StaticResource Border}"
                            BorderThickness="1" CornerRadius="12" Padding="16">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top" Text="Chi tiết đơn hàng" FontSize="16" FontWeight="Bold"
                                       Foreground="{StaticResource Ink}" Margin="0,0,0,10"/>
                            <DataGrid ItemsSource="{Binding OrderLines}" AutoGenerateColumns="False" IsReadOnly="True"
                                      HeadersVisibility="Column" CanUserAddRows="False" GridLinesVisibility="Horizontal">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Sản phẩm" Binding="{Binding ProductName}" Width="*"/>
                                    <DataGridTextColumn Header="SL" Binding="{Binding Quantity}" Width="50"/>
                                    <DataGridTextColumn Header="Thành tiền" Binding="{Binding LineTotalText}" Width="120"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>

<UserControl x:Class="QLXeMay.Windows.SearchWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Background="{StaticResource Surface}" FontFamily="Segoe UI">
    <UserControl.Resources>
        <Style x:Key="Cmd" TargetType="{x:Type Button}" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Height" Value="36"/>
            <Setter Property="MinWidth" Value="106"/>
            <Setter Property="Margin" Value="5"/>
        </Style>
    </UserControl.Resources>
    <DockPanel Margin="18">
        <Border DockPanel.Dock="Top" Style="{StaticResource CardBorder}" Padding="12" Margin="0,0,0,12">
            <TextBlock Text="{Binding WindowTitle}" FontSize="22" FontWeight="Bold" Foreground="{StaticResource Ink}" HorizontalAlignment="Center"/>
        </Border>

        <Border DockPanel.Dock="Top" Style="{StaticResource CardBorder}" Padding="14" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="Tiêu chí tìm kiếm" FontWeight="Bold" FontSize="16" Margin="4,0,0,10"/>
                <WrapPanel x:Name="CriteriaPanel" HorizontalAlignment="Center"/>
                <WrapPanel HorizontalAlignment="Center" Margin="0,10,0,0">
                    <Button Content="Tìm kiếm" Command="{Binding SearchCommand}" Style="{StaticResource AccentButton}" MinWidth="112" Height="36"/>
                    <Button Content="Tìm lại" Command="{Binding ResetCommand}" Style="{StaticResource Cmd}"/>
                    <Button Content="Xuất Excel" Command="{Binding ExportCommand}" Style="{StaticResource Cmd}"/>
                    <Button Content="Đóng" Command="{Binding CloseCommand}" Style="{StaticResource Cmd}"/>
                </WrapPanel>
            </StackPanel>
        </Border>

        <Border Style="{StaticResource CardBorder}" Padding="10">
            <DataGrid ItemsSource="{Binding ResultView}"
                      IsReadOnly="True"
                      AutoGenerateColumns="True"
                      AutoGeneratingColumn="ResultGrid_AutoGeneratingColumn"
                      CanUserAddRows="False"/>
        </Border>
    </DockPanel>
</UserControl>

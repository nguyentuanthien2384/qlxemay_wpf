<Window x:Class="QLXeMay.Windows.SearchWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding WindowTitle}" Height="620" Width="920" WindowStartupLocation="CenterOwner" Background="White">
    <DockPanel Margin="12">
        <TextBlock DockPanel.Dock="Top" Text="{Binding WindowTitle}" FontSize="22" FontWeight="Bold" Foreground="DarkGreen" HorizontalAlignment="Center" Margin="0,0,0,10"/>
        <StackPanel DockPanel.Dock="Top" Orientation="Vertical">
            <WrapPanel x:Name="CriteriaPanel" Margin="0,0,0,6"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,8">
                <Button Content="Tìm kiếm" Command="{Binding SearchCommand}"/>
                <Button Content="Tìm lại" Command="{Binding ResetCommand}"/>
                <Button Content="Xuất Excel" Command="{Binding ExportCommand}"/>
                <Button Content="Đóng" Command="{Binding CloseCommand}"/>
            </StackPanel>
        </StackPanel>
        <DataGrid ItemsSource="{Binding ResultView}" IsReadOnly="True" AutoGenerateColumns="True" CanUserAddRows="False"/>
    </DockPanel>
</Window>

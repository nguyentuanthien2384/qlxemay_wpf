<UserControl x:Class="QLXeMay.Windows.SearchWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Background="#F1F5F9" FontFamily="Segoe UI">
    <UserControl.Resources>
        <SolidColorBrush x:Key="Panel" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="Line" Color="#E2E8F0"/>
        <Style x:Key="Cmd" TargetType="{x:Type Button}">
            <Setter Property="Height" Value="34"/>
            <Setter Property="MinWidth" Value="100"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
        </Style>
    </UserControl.Resources>
    <DockPanel Margin="18">
        <Border DockPanel.Dock="Top" Background="#FFFFFF" BorderBrush="{StaticResource Line}" BorderThickness="1" Padding="10" Margin="0,0,0,12">
            <TextBlock Text="{Binding WindowTitle}" FontSize="22" FontWeight="Bold" Foreground="#0F172A" HorizontalAlignment="Center"/>
        </Border>

        <Border DockPanel.Dock="Top" Background="{StaticResource Panel}" BorderBrush="{StaticResource Line}" BorderThickness="1" Padding="12" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="Tiêu chí tìm kiếm" FontWeight="Bold" FontSize="16" Margin="4,0,0,8"/>
                <WrapPanel x:Name="CriteriaPanel"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8,0,0">
                    <Button Content="Tìm kiếm" Command="{Binding SearchCommand}" Style="{StaticResource Cmd}" Background="#2563EB" BorderBrush="#1D4ED8" Foreground="White"/>
                    <Button Content="Tìm lại" Command="{Binding ResetCommand}" Style="{StaticResource Cmd}"/>
                    <Button Content="Xuất Excel" Command="{Binding ExportCommand}" Style="{StaticResource Cmd}"/>
                    <Button Content="Đóng" Command="{Binding CloseCommand}" Style="{StaticResource Cmd}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Background="#F8FAFC" BorderBrush="{StaticResource Line}" BorderThickness="1" Padding="10">
            <DataGrid ItemsSource="{Binding ResultView}" IsReadOnly="True" AutoGenerateColumns="True" CanUserAddRows="False" AlternatingRowBackground="#F8FAFC"/>
        </Border>
    </DockPanel>
</UserControl>

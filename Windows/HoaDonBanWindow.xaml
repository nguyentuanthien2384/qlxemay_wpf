<UserControl x:Class="QLXeMay.Windows.HoaDonBanWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Background="#F1F5F9" FontFamily="Segoe UI">
    <UserControl.Resources>
        <SolidColorBrush x:Key="Panel" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="Line" Color="#E2E8F0"/>
        <Style x:Key="Cmd" TargetType="{x:Type Button}">
            <Setter Property="Height" Value="34"/>
            <Setter Property="MinWidth" Value="96"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
        </Style>
    </UserControl.Resources>
    <DockPanel Margin="18">
        <Border DockPanel.Dock="Top" Background="#FFFFFF" BorderBrush="{StaticResource Line}" BorderThickness="1" Padding="10" Margin="0,0,0,12">
            <TextBlock Text="HÓA ĐƠN BÁN HÀNG" FontSize="22" FontWeight="Bold" Foreground="#0F172A" HorizontalAlignment="Center"/>
        </Border>
        <Border DockPanel.Dock="Bottom" Background="{StaticResource Panel}" BorderBrush="{StaticResource Line}" BorderThickness="1" Padding="10" Margin="0,12,0,0">
            <StackPanel>
                <WrapPanel>
                    <Label Content="Tổng tiền:" FontWeight="Bold"/><TextBlock Text="{Binding Total}" Margin="4" FontWeight="Bold" VerticalAlignment="Center"/>
                    <Label Content="Thuế:" Margin="24,0,0,0"/><TextBlock Text="{Binding Tax}" Margin="4" VerticalAlignment="Center"/>
                    <Label Content="Đặt cọc:" Margin="24,0,0,0"/><TextBlock Text="{Binding Deposit}" Margin="4" VerticalAlignment="Center"/>
                    <Label Content="Bằng chữ:" Margin="24,0,0,0"/><TextBlock Text="{Binding AmountInWords}" Margin="4" FontStyle="Italic" Foreground="#1E40AF" VerticalAlignment="Center"/>
                </WrapPanel>
                <WrapPanel HorizontalAlignment="Center" Margin="0,6,0,0">
                    <Button Content="Thêm hóa đơn" Command="{Binding NewInvoiceCommand}" Style="{StaticResource Cmd}" Background="#2563EB" BorderBrush="#1D4ED8" Foreground="White"/>
                    <Button Content="Lưu mặt hàng" Command="{Binding SaveLineCommand}" Style="{StaticResource Cmd}"/>
                    <Button Content="Xóa dòng" Command="{Binding DeleteLineCommand}" Style="{StaticResource Cmd}"/>
                    <Button Content="Bỏ qua" Command="{Binding ResetCommand}" Style="{StaticResource Cmd}"/>
                    <Button Content="Hủy hóa đơn" Command="{Binding CancelInvoiceCommand}" Style="{StaticResource Cmd}"/>
                    <Button Content="Xuất Excel" Command="{Binding ExportCommand}" Style="{StaticResource Cmd}"/>
                    <Button Content="Đóng" Command="{Binding CloseCommand}" Style="{StaticResource Cmd}"/>
                </WrapPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,6,0,0">
                    <Label Content="Mã hóa đơn:"/>
                    <ComboBox Width="210" ItemsSource="{Binding InvoiceNumbers}" SelectedValuePath="soddh" DisplayMemberPath="soddh" SelectedValue="{Binding SelectedSearchInvoiceNo, Mode=TwoWay}"/>
                    <Button Content="Tìm kiếm" Command="{Binding SearchInvoiceCommand}" Style="{StaticResource Cmd}"/>
                </StackPanel>
            </StackPanel>
        </Border>
        <Grid>
            <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
            <GroupBox Header="Thông tin chung" Grid.Row="0" Margin="0,0,0,8" Background="{StaticResource Panel}" BorderBrush="{StaticResource Line}">
                <UniformGrid Columns="4" Margin="10">
                    <StackPanel><Label Content="Mã hóa đơn bán"/><TextBox Text="{Binding InvoiceNo, Mode=OneWay}" IsReadOnly="True"/></StackPanel>
                    <StackPanel><Label Content="Ngày mua"/><DatePicker SelectedDate="{Binding InvoiceDate}" IsEnabled="{Binding IsInvoiceActive}"/></StackPanel>
                    <StackPanel><Label Content="Mã nhân viên"/><ComboBox ItemsSource="{Binding Employees}" SelectedValuePath="manv" DisplayMemberPath="manv" SelectedValue="{Binding SelectedEmployeeId, Mode=TwoWay}" IsEnabled="{Binding IsInvoiceActive}"/></StackPanel>
                    <StackPanel><Label Content="Tên nhân viên"/><TextBox Text="{Binding EmployeeName, Mode=OneWay}" IsReadOnly="True"/></StackPanel>
                    <StackPanel><Label Content="Mã khách"/><ComboBox ItemsSource="{Binding Customers}" SelectedValuePath="makhach" DisplayMemberPath="makhach" SelectedValue="{Binding SelectedCustomerId, Mode=TwoWay}" IsEnabled="{Binding IsInvoiceActive}"/></StackPanel>
                    <StackPanel><Label Content="Tên khách"/><TextBox Text="{Binding CustomerName, Mode=OneWay}" IsReadOnly="True"/></StackPanel>
                    <StackPanel><Label Content="Địa chỉ"/><TextBox Text="{Binding CustomerAddress, Mode=OneWay}" IsReadOnly="True"/></StackPanel>
                    <StackPanel><Label Content="Điện thoại"/><TextBox Text="{Binding CustomerPhone, Mode=OneWay}" IsReadOnly="True"/></StackPanel>
                </UniformGrid>
            </GroupBox>
            <GroupBox Header="Thông tin mặt hàng" Grid.Row="1" Margin="0,0,0,8" Background="{StaticResource Panel}" BorderBrush="{StaticResource Line}">
                <UniformGrid Columns="5" Margin="10">
                    <StackPanel><Label Content="Mã hàng"/><ComboBox ItemsSource="{Binding Products}" SelectedValuePath="mahang" DisplayMemberPath="mahang" SelectedValue="{Binding SelectedProductId, Mode=TwoWay}" IsEnabled="{Binding IsInvoiceActive}"/></StackPanel>
                    <StackPanel><Label Content="Tên hàng"/><TextBox Text="{Binding ProductName, Mode=OneWay}" IsReadOnly="True"/></StackPanel>
                    <StackPanel><Label Content="Số lượng"/><TextBox Text="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding IsInvoiceActive}"/></StackPanel>
                    <StackPanel><Label Content="Giảm giá (%)"/><TextBox Text="{Binding Discount, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding IsInvoiceActive}"/></StackPanel>
                    <StackPanel><Label Content="Thành tiền"/><TextBox Text="{Binding LineTotal, Mode=OneWay}" IsReadOnly="True"/></StackPanel>
                </UniformGrid>
            </GroupBox>
            <Border Grid.Row="2" Background="#F8FAFC" BorderBrush="{StaticResource Line}" BorderThickness="1" Padding="10">
                <DataGrid ItemsSource="{Binding DetailsView}" SelectedItem="{Binding SelectedDetail, Mode=TwoWay}" IsReadOnly="True" AutoGenerateColumns="True" CanUserAddRows="False" AlternatingRowBackground="#F8FAFC"/>
            </Border>
        </Grid>
    </DockPanel>
</UserControl>

<Window x:Class="QLXeMay.Windows.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Đăng nhập hệ thống"
        Width="900" Height="560" MinWidth="800" MinHeight="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        FontFamily="Segoe UI"
        Background="{StaticResource Surface}"
        KeyUp="Window_KeyUp">

    <Border Margin="0" Background="{StaticResource Card}" CornerRadius="0">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ===== Left panel: Login form ===== -->
            <Grid Grid.Column="0" Background="White">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="280">

                    <!-- Title -->
                    <TextBlock Text="Đăng nhập" FontWeight="Bold" FontSize="26"
                               Foreground="{StaticResource Ink}" HorizontalAlignment="Center" Margin="0,0,0,20"/>

                    <!-- User Avatar Icon -->
                    <Border Width="80" Height="80" CornerRadius="12" Background="{StaticResource Accent}"
                            HorizontalAlignment="Center" Margin="0,0,0,30">
                        <TextBlock Text="👤" FontSize="42" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <!-- Username field with icon -->
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="30"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="👤" FontSize="14" VerticalAlignment="Center" HorizontalAlignment="Center"
                                   Foreground="{StaticResource Muted}"/>
                        <TextBox x:Name="UserNameTextBox" Grid.Column="1" Height="38" Margin="0"
                                 BorderThickness="0,0,0,1" BorderBrush="{StaticResource BorderStrong}"
                                 Background="Transparent"
                                 Text="{Binding UserName, UpdateSourceTrigger=PropertyChanged}"/>
                    </Grid>

                    <!-- Password field with icon -->
                    <Grid Margin="0,8,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="30"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="🔑" FontSize="14" VerticalAlignment="Center" HorizontalAlignment="Center"
                                   Foreground="{StaticResource Muted}"/>
                        <Grid Grid.Column="1">
                            <PasswordBox x:Name="PasswordInput" Height="38" Margin="0"
                                         BorderThickness="0,0,0,1" BorderBrush="{StaticResource BorderStrong}"
                                         Background="Transparent"
                                         PasswordChanged="PasswordInput_PasswordChanged"/>
                            <TextBox x:Name="VisiblePasswordBox" Height="38" Margin="0"
                                     BorderThickness="0,0,0,1" BorderBrush="{StaticResource BorderStrong}"
                                     Background="Transparent"
                                     TextChanged="VisiblePasswordBox_TextChanged" Visibility="Collapsed"/>
                        </Grid>
                    </Grid>

                    <!-- Show/hide password toggle -->
                    <Button x:Name="TogglePasswordButton" Content="Hiện mật khẩu"
                            Click="TogglePasswordButton_Click" Style="{StaticResource GhostButton}"
                            HorizontalAlignment="Right" Height="28" MinWidth="0" Padding="6,2"
                            FontSize="11" Margin="0,2,0,0"/>

                    <!-- Caps Lock warning -->
                    <TextBlock x:Name="CapsLockWarning" Text="⚠ Caps Lock đang bật."
                               Foreground="{StaticResource Warning}" FontWeight="SemiBold" FontSize="12"
                               Visibility="Collapsed" Margin="0,4,0,0" HorizontalAlignment="Center"/>

                    <!-- Error message -->
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource Danger}"
                               FontWeight="SemiBold" FontSize="12" TextWrapping="Wrap"
                               Margin="0,4,0,0" HorizontalAlignment="Center"/>

                    <!-- LOGIN Button -->
                    <Button Content="LOGIN" Command="{Binding LoginCommand}" IsDefault="True"
                            Style="{StaticResource AccentButton}" Height="42" Margin="0,20,0,0"
                            FontSize="15" FontWeight="Bold"/>

                    <!-- Secondary actions -->
                    <Grid Margin="0,14,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="Đăng ký" Command="{Binding RegisterCommand}"
                                Style="{StaticResource GhostButton}" Height="34" Margin="0,0,4,0"
                                FontSize="12"/>
                        <Button Grid.Column="1" Content="Thoát" Command="{Binding CancelCommand}"
                                Height="34" Margin="4,0,0,0" FontSize="12"/>
                    </Grid>

                    <!-- Customer registration -->
                    <Button Content="🛒  Đăng ký tài khoản mua hàng" Click="CustomerRegister_Click"
                            Style="{StaticResource AccentButton}" Height="36" Margin="0,8,0,0"
                            FontSize="12"/>

                </StackPanel>
            </Grid>

            <!-- ===== Right panel: Brand / Visual ===== -->
            <Border Grid.Column="1" CornerRadius="0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#E8956B" Offset="0"/>
                        <GradientStop Color="#5BA0C4" Offset="0.5"/>
                        <GradientStop Color="#3B7EA1" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <!-- Overlay for readability -->
                    <Border Background="#20000000"/>
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="30">
                        <TextBlock Text="🏍" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                        <TextBlock Text="Moto Manager" Foreground="White" FontSize="36" FontWeight="Bold"
                                   HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"/>
                        <TextBlock Text="TechShop" Foreground="White" FontSize="36" FontWeight="Bold"
                                   HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

        </Grid>
    </Border>
</Window>

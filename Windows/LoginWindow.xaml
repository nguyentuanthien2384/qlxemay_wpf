<Window x:Class="QLXeMay.Windows.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Đăng nhập hệ thống"
        Width="940" Height="580" MinWidth="860" MinHeight="540"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        FontFamily="Segoe UI"
        Background="{StaticResource Surface}"
        KeyUp="Window_KeyUp">
    <Window.Resources>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{StaticResource Ink}"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
    </Window.Resources>

    <Border Margin="18" Background="{StaticResource Card}" BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="14">
        <Border.Effect>
            <DropShadowEffect Color="#0F172A" Opacity="0.10" BlurRadius="24" ShadowDepth="0"/>
        </Border.Effect>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="340"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ===== Brand panel ===== -->
            <Border Grid.Column="0" CornerRadius="14,0,0,14">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#1E293B" Offset="0"/>
                        <GradientStop Color="#0F172A" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <DockPanel Margin="28,32">
                    <StackPanel DockPanel.Dock="Top">
                        <Border Width="64" Height="64" CornerRadius="16" Background="#2563EB" HorizontalAlignment="Left">
                            <TextBlock Text="🏍" FontSize="32" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="MOTO MANAGER" Foreground="#60A5FA" FontSize="12" FontWeight="Bold" Margin="0,22,0,0"/>
                        <TextBlock Text="Hệ thống quản lý&#x0a;cửa hàng xe máy" Foreground="White" FontSize="24" FontWeight="Bold" Margin="0,6,0,0" TextWrapping="Wrap"/>
                        <TextBlock Text="Quản lý xe, kho, bán hàng, khách hàng và doanh thu trên một nền tảng duy nhất."
                                   Foreground="{StaticResource BrandMuted}" FontSize="13" TextWrapping="Wrap" Margin="0,12,0,0"/>
                    </StackPanel>

                    <StackPanel DockPanel.Dock="Bottom">
                        <TextBlock Text="✓  Phân quyền theo vai trò" Foreground="{StaticResource BrandText}" FontSize="13" Margin="0,4"/>
                        <TextBlock Text="✓  Mã hóa mật khẩu &amp; khóa tài khoản" Foreground="{StaticResource BrandText}" FontSize="13" Margin="0,4"/>
                        <TextBlock Text="✓  Nhật ký hệ thống đầy đủ" Foreground="{StaticResource BrandText}" FontSize="13" Margin="0,4"/>
                        <Border Height="1" Background="#334155" Margin="0,16,0,12"/>
                        <TextBlock Text="© 2025 QLXeMay" Foreground="{StaticResource BrandMuted}" FontSize="11"/>
                    </StackPanel>
                    <Grid/>
                </DockPanel>
            </Border>

            <!-- ===== Form panel ===== -->
            <Grid Grid.Column="1" Background="{StaticResource Card}">
                <Border Width="400" Padding="40,0" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="28"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="16"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="6"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="10"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="14"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="20"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0">
                            <TextBlock Text="Đăng nhập" FontWeight="Bold" FontSize="28" Foreground="{StaticResource Ink}"/>
                            <TextBlock Text="Nhập thông tin tài khoản để tiếp tục" Foreground="{StaticResource Muted}" FontSize="13" Margin="0,6,0,0"/>
                        </StackPanel>

                        <!-- Username -->
                        <StackPanel Grid.Row="2">
                            <TextBlock Text="Tài khoản" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="UserNameTextBox" Height="42" Margin="0"
                                     Text="{Binding UserName, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <!-- Password -->
                        <StackPanel Grid.Row="4">
                            <TextBlock Text="Mật khẩu" Style="{StaticResource FieldLabel}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Grid Grid.Column="0">
                                    <PasswordBox x:Name="PasswordInput" Height="42" Margin="0" PasswordChanged="PasswordInput_PasswordChanged"/>
                                    <TextBox x:Name="VisiblePasswordBox" Height="42" Margin="0" TextChanged="VisiblePasswordBox_TextChanged" Visibility="Collapsed"/>
                                </Grid>
                                <Button x:Name="TogglePasswordButton" Grid.Column="1" Content="Hiện"
                                        Click="TogglePasswordButton_Click" Style="{StaticResource GhostButton}"
                                        MinWidth="58" Height="42" Margin="8,0,0,0" Padding="8,0"/>
                            </Grid>
                        </StackPanel>

                        <TextBlock x:Name="CapsLockWarning" Grid.Row="6" Text="⚠ Caps Lock đang bật."
                                   Foreground="{StaticResource Warning}" FontWeight="SemiBold" FontSize="12" Visibility="Collapsed"/>

                        <TextBlock Grid.Row="8" Text="{Binding ErrorMessage}" Foreground="{StaticResource Danger}"
                                   FontWeight="SemiBold" FontSize="12" TextWrapping="Wrap"/>

                        <!-- Primary action -->
                        <Button Grid.Row="10" Content="Đăng nhập" Command="{Binding LoginCommand}" IsDefault="True"
                                Style="{StaticResource AccentButton}" Height="44" Margin="0" FontSize="15"/>

                        <!-- Secondary actions + helper -->
                        <StackPanel Grid.Row="12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" Content="Đăng ký" Command="{Binding RegisterCommand}"
                                        Style="{StaticResource GhostButton}" Height="40" Margin="0,0,5,0"/>
                                <Button Grid.Column="1" Content="Thoát" Command="{Binding CancelCommand}"
                                        Height="40" Margin="5,0,0,0"/>
                            </Grid>
                            <Border Background="{StaticResource AccentSoft}" BorderBrush="#BFDBFE" BorderThickness="1"
                                    CornerRadius="8" Padding="12" Margin="0,14,0,0">
                                <TextBlock Text="{Binding HelperMessage}" Foreground="{StaticResource Muted}" TextWrapping="Wrap" FontSize="12"/>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>

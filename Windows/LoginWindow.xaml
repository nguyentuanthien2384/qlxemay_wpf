<Window x:Class="QLXeMay.Windows.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Đăng nhập hệ thống"
        Width="500" Height="620"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        FontFamily="Segoe UI"
        Background="#F4F7F5">
    <Window.Resources>
        <SolidColorBrush x:Key="PrimaryBrush" Color="#0B6B3A"/>
        <SolidColorBrush x:Key="PrimaryDarkBrush" Color="#084F2D"/>
        <SolidColorBrush x:Key="LineBrush" Color="#DDE7E1"/>
        <SolidColorBrush x:Key="MutedBrush" Color="#69756F"/>

        <Style x:Key="LoginTextBoxStyle" TargetType="{x:Type TextBox}">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style x:Key="LoginPasswordBoxStyle" TargetType="{x:Type PasswordBox}">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="7"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{StaticResource PrimaryDarkBrush}"/>
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource PrimaryDarkBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}"/>
            <Setter Property="Foreground" Value="#17211C"/>
        </Style>
    </Window.Resources>

    <Grid Margin="26">
        <Border Background="White" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="8" Padding="26">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="24"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="14"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="14"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="18"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <TextBlock Text="Đăng nhập"
                               Foreground="{StaticResource PrimaryBrush}"
                               FontSize="30"
                               FontWeight="Bold"/>
                    <TextBlock Text="Quản lý cửa hàng bán xe máy"
                               Foreground="{StaticResource MutedBrush}"
                               FontSize="14"
                               Margin="0,6,0,0"/>
                </StackPanel>

                <StackPanel Grid.Row="2">
                    <TextBlock Text="Tên đăng nhập" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <TextBox x:Name="UserNameTextBox"
                             Text="{Binding UserName, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource LoginTextBoxStyle}"/>
                </StackPanel>

                <StackPanel Grid.Row="4">
                    <TextBlock Text="Mật khẩu" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <PasswordBox x:Name="PasswordInput"
                                 PasswordChanged="PasswordInput_PasswordChanged"
                                 Style="{StaticResource LoginPasswordBoxStyle}"/>
                </StackPanel>

                <Border Grid.Row="6"
                        Background="#F8FAF8"
                        BorderBrush="{StaticResource LineBrush}"
                        BorderThickness="1"
                        CornerRadius="7"
                        Padding="12">
                    <StackPanel>
                        <TextBlock Text="Tài khoản mẫu theo phân quyền"
                                   Foreground="#17211C"
                                   FontWeight="SemiBold"
                                   FontSize="13"
                                   Margin="0,0,0,6"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="92"/>
                                <ColumnDefinition Width="112"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="admin" FontWeight="SemiBold"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="Admin@123"/>
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="Quản trị" Foreground="{StaticResource MutedBrush}"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="manager" FontWeight="SemiBold"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="Manager@123"/>
                            <TextBlock Grid.Row="1" Grid.Column="2" Text="Quản lý" Foreground="{StaticResource MutedBrush}"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="sales" FontWeight="SemiBold"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="Sales@123"/>
                            <TextBlock Grid.Row="2" Grid.Column="2" Text="Bán hàng" Foreground="{StaticResource MutedBrush}"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="warehouse" FontWeight="SemiBold"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="Warehouse@123"/>
                            <TextBlock Grid.Row="3" Grid.Column="2" Text="Thủ kho" Foreground="{StaticResource MutedBrush}"/>

                            <TextBlock Grid.Row="4" Grid.Column="0" Text="viewer" FontWeight="SemiBold"/>
                            <TextBlock Grid.Row="4" Grid.Column="1" Text="Viewer@123"/>
                            <TextBlock Grid.Row="4" Grid.Column="2" Text="Chỉ xem" Foreground="{StaticResource MutedBrush}"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <TextBlock Grid.Row="8"
                           Text="{Binding ErrorMessage}"
                           Foreground="#B91C1C"
                           TextWrapping="Wrap"/>

                <Grid Grid.Row="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Content="Thoát"
                            Command="{Binding CancelCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"/>
                    <Button Grid.Column="2"
                            Content="Đăng nhập"
                            Command="{Binding LoginCommand}"
                            IsDefault="True"
                            Style="{StaticResource PrimaryButtonStyle}"/>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>

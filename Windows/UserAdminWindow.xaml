<Window x:Class="QLXeMay.Windows.UserAdminWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Quản trị tài khoản và phân quyền"
        Height="660" Width="980"
        WindowStartupLocation="CenterOwner"
        FontFamily="Segoe UI"
        Background="#F4F7F5">
    <Window.Resources>
        <SolidColorBrush x:Key="PrimaryBrush" Color="#0B6B3A"/>
        <SolidColorBrush x:Key="LineBrush" Color="#DDE7E1"/>
        <SolidColorBrush x:Key="MutedBrush" Color="#69756F"/>
    </Window.Resources>

    <DockPanel Margin="18">
        <TextBlock DockPanel.Dock="Top"
                   Text="QUẢN TRỊ TÀI KHOẢN VÀ PHÂN QUYỀN"
                   FontSize="22"
                   FontWeight="Bold"
                   Foreground="{StaticResource PrimaryBrush}"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,14"/>

        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,14,0,0">
            <Button Content="Tạo tài khoản" Command="{Binding CreateUserCommand}"/>
            <Button Content="Cập nhật" Command="{Binding UpdateUserCommand}"/>
            <Button Content="Reset mật khẩu" Command="{Binding ResetPasswordCommand}"/>
            <Button Content="Làm mới" Command="{Binding RefreshCommand}"/>
            <Button Content="Bỏ chọn" Command="{Binding ClearCommand}"/>
            <Button Content="Đóng" Command="{Binding CloseCommand}"/>
        </StackPanel>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="8" Padding="18">
                <StackPanel>
                    <TextBlock Text="Thông tin tài khoản" FontSize="17" FontWeight="SemiBold"/>
                    <TextBlock Text="Tạo user mới hoặc chọn user bên phải để cập nhật." Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Margin="0,4,0,16"/>

                    <Label Content="Tên đăng nhập"/>
                    <TextBox Text="{Binding NewUserName, UpdateSourceTrigger=PropertyChanged}"/>

                    <Label Content="Tên hiển thị"/>
                    <TextBox Text="{Binding DisplayName, UpdateSourceTrigger=PropertyChanged}"/>

                    <Label Content="Vai trò"/>
                    <ComboBox ItemsSource="{Binding Roles}"
                              SelectedItem="{Binding SelectedRole, Mode=TwoWay}"
                              DisplayMemberPath="DisplayName"/>

                    <Label Content="Mật khẩu mới"/>
                    <PasswordBox x:Name="PasswordInput"
                                 PasswordChanged="PasswordInput_PasswordChanged"
                                 Height="32"
                                 MinWidth="150"
                                 Margin="4"
                                 VerticalContentAlignment="Center"/>

                    <CheckBox Content="Tài khoản hoạt động"
                              IsChecked="{Binding IsActive, Mode=TwoWay}"
                              Margin="4,12,4,4"/>

                    <Border Background="#F8FAF8" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="7" Padding="10" Margin="0,14,0,0">
                        <TextBlock Text="Lưu ý: khi tạo tài khoản hoặc reset mật khẩu, mật khẩu phải có ít nhất 6 ký tự."
                                   Foreground="{StaticResource MutedBrush}"
                                   TextWrapping="Wrap"/>
                    </Border>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Background="White" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="8" Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Text="Danh sách tài khoản" FontSize="17" FontWeight="SemiBold"/>
                        <TextBlock Text="Chọn một dòng để chỉnh vai trò, trạng thái hoặc reset mật khẩu."
                                   Foreground="{StaticResource MutedBrush}"
                                   Margin="0,4,0,0"/>
                    </StackPanel>

                    <DataGrid Grid.Row="2"
                              ItemsSource="{Binding Users}"
                              SelectedItem="{Binding SelectedUser, Mode=TwoWay}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserAddRows="False"
                              SelectionMode="Single">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="User" Binding="{Binding UserName}" Width="110"/>
                            <DataGridTextColumn Header="Tên hiển thị" Binding="{Binding DisplayName}" Width="160"/>
                            <DataGridTextColumn Header="Vai trò" Binding="{Binding RoleDisplayName}" Width="150"/>
                            <DataGridCheckBoxColumn Header="Hoạt động" Binding="{Binding IsActive}" Width="80"/>
                            <DataGridTextColumn Header="Sai login" Binding="{Binding FailedLoginCount}" Width="80"/>
                            <DataGridTextColumn Header="Đăng nhập cuối" Binding="{Binding LastLoginAt}" Width="130"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>
    </DockPanel>
</Window>

<Window x:Class="QLXeMay.Windows.ChangePasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Đổi mật khẩu bắt buộc"
        Width="540" Height="430" MinWidth="500" MinHeight="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        FontFamily="Segoe UI"
        Background="#F1F5F9">
    <Window.Resources>
        <Style x:Key="PasswordInput" TargetType="{x:Type PasswordBox}">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
        </Style>
        <Style x:Key="ActionButton" TargetType="{x:Type Button}">
            <Setter Property="Height" Value="38"/>
            <Setter Property="MinWidth" Value="120"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="BorderBrush" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Border Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Padding="24">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="14"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="14"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="14"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="18"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <TextBlock Text="Đổi mật khẩu" FontSize="24" FontWeight="Bold" Foreground="#2563EB"/>
                    <TextBlock Text="Mật khẩu hiện tại là mật khẩu tạm hoặc mật khẩu cũ. Bạn cần đặt mật khẩu mới trước khi vào hệ thống." Foreground="#64748B" TextWrapping="Wrap" Margin="0,8,0,0"/>
                </StackPanel>

                <StackPanel Grid.Row="2">
                    <TextBlock Text="Mật khẩu hiện tại" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <PasswordBox x:Name="CurrentPasswordBox" Style="{StaticResource PasswordInput}"/>
                </StackPanel>

                <StackPanel Grid.Row="4">
                    <TextBlock Text="Mật khẩu mới" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <PasswordBox x:Name="NewPasswordBox" Style="{StaticResource PasswordInput}"/>
                </StackPanel>

                <StackPanel Grid.Row="6">
                    <TextBlock Text="Nhập lại mật khẩu mới" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <PasswordBox x:Name="ConfirmPasswordBox" Style="{StaticResource PasswordInput}"/>
                </StackPanel>

                <TextBlock x:Name="MessageTextBlock" Grid.Row="8" TextWrapping="Wrap" FontWeight="SemiBold" Foreground="#DC2626"/>

                <StackPanel Grid.Row="10" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Hủy" Click="Cancel_Click" Style="{StaticResource ActionButton}" Background="#FFFFFF" BorderBrush="#E2E8F0" Foreground="#0F172A"/>
                    <Button Content="Lưu mật khẩu" Click="Save_Click" Style="{StaticResource ActionButton}" Margin="10,0,0,0"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>

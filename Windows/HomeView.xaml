<UserControl x:Class="QLXeMay.Windows.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="Segoe UI" Background="{StaticResource Surface}">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <Style x:Key="TileButton" TargetType="Button">
            <Setter Property="MinHeight" Value="96"/>
            <Setter Property="Margin" Value="0,0,16,16"/>
            <Setter Property="Padding" Value="18"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Top"/>
            <Setter Property="Background" Value="{StaticResource Card}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome" CornerRadius="12" Background="{TemplateBinding Background}"
                                BorderBrush="{StaticResource Border}" BorderThickness="1" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Stretch" VerticalAlignment="Top"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource Accent}"/>
                                <Setter TargetName="Chrome" Property="Background" Value="{StaticResource CardAlt}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Chrome" Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ChipButton" TargetType="Button">
            <Setter Property="Height" Value="34"/>
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="Margin" Value="0,0,8,8"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="Foreground" Value="{StaticResource Ink}"/>
            <Setter Property="Background" Value="{StaticResource CardAlt}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome" CornerRadius="17" Background="{TemplateBinding Background}"
                                BorderBrush="{StaticResource Border}" BorderThickness="1" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{StaticResource AccentSoft}"/>
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource Accent}"/>
                                <Setter Property="Foreground" Value="{StaticResource AccentPressed}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Chrome" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28">
            <!-- Hero -->
            <Border CornerRadius="14" Padding="28" Margin="0,0,0,22">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#6366F1" Offset="0"/>
                        <GradientStop Color="#3B82F6" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="QUẢN LÝ BÁN XE MÁY" Foreground="#93C5FD" FontSize="12" FontWeight="Bold"/>
                        <TextBlock Text="Chào mừng trở lại 👋" Foreground="White" FontSize="28" FontWeight="Bold" Margin="0,6,0,0"/>
                        <TextBlock Text="Theo dõi danh mục xe, kho hàng, đơn bán, khách hàng và doanh thu — tất cả trong một nơi."
                                   Foreground="#CBD5E1" FontSize="13.5" TextWrapping="Wrap" Margin="0,8,0,18" MaxWidth="520" HorizontalAlignment="Left"/>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="＋ Lập đơn bán" Command="{Binding OpenHoaDonBanCommand}" Height="40" MinWidth="140" Margin="0,0,10,0" Foreground="#1D4ED8" Background="White" BorderBrush="White" Visibility="{Binding CanSalesInvoice, Converter={StaticResource BoolToVis}}"/>
                            <Button Content="📦 Nhập hàng" Command="{Binding OpenHoaDonNhapCommand}" Style="{StaticResource GhostButton}" Height="40" MinWidth="130" Margin="0,0,10,0" Foreground="White" BorderBrush="#BFD2FB" Background="#3B82F6" Visibility="{Binding CanPurchaseInvoice, Converter={StaticResource BoolToVis}}"/>
                            <Button Content="🤖 Trợ lý AI" Command="{Binding OpenAiCommand}" Style="{StaticResource GhostButton}" Height="40" MinWidth="120" Foreground="White" BorderBrush="#BFD2FB" Background="#3B82F6" Visibility="{Binding CanAi, Converter={StaticResource BoolToVis}}"/>
                        </StackPanel>
                    </StackPanel>
                    <Border Grid.Column="1" Width="150" Height="150" CornerRadius="20" Background="#FFFFFF22" Margin="20,0,0,0">
                        <TextBlock Text="🏍" FontSize="84" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </Grid>
            </Border>

            <!-- KPI cards -->
            <UniformGrid Columns="4" Margin="0,0,0,6">
                <Border Style="{StaticResource CardBorder}" Padding="18" Margin="0,0,16,0">
                    <StackPanel>
                        <TextBlock Text="💰  DOANH THU" Foreground="{StaticResource Muted}" FontSize="11" FontWeight="Bold"/>
                        <TextBlock Text="{Binding RevenueText}" Foreground="{StaticResource Accent}" FontSize="24" FontWeight="Bold" Margin="0,8,0,0"/>
                        <TextBlock Text="Tổng tiền các đơn bán" Foreground="{StaticResource Muted}" FontSize="11.5" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource CardBorder}" Padding="18" Margin="0,0,16,0">
                    <StackPanel>
                        <TextBlock Text="🧾  ĐƠN BÁN" Foreground="{StaticResource Muted}" FontSize="11" FontWeight="Bold"/>
                        <TextBlock Text="{Binding OrderCountText}" Foreground="{StaticResource Ink}" FontSize="24" FontWeight="Bold" Margin="0,8,0,0"/>
                        <TextBlock Text="Số đơn đặt hàng" Foreground="{StaticResource Muted}" FontSize="11.5" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource CardBorder}" Padding="18" Margin="0,0,16,0">
                    <StackPanel>
                        <TextBlock Text="🏍  TỒN KHO" Foreground="{StaticResource Muted}" FontSize="11" FontWeight="Bold"/>
                        <TextBlock Text="{Binding StockText}" Foreground="{StaticResource Ink}" FontSize="24" FontWeight="Bold" Margin="0,8,0,0"/>
                        <TextBlock Text="Tổng số xe trong kho" Foreground="{StaticResource Muted}" FontSize="11.5" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource CardBorder}" Padding="18">
                    <StackPanel>
                        <TextBlock Text="👥  KHÁCH HÀNG" Foreground="{StaticResource Muted}" FontSize="11" FontWeight="Bold"/>
                        <TextBlock Text="{Binding CustomerText}" Foreground="{StaticResource Success}" FontSize="24" FontWeight="Bold" Margin="0,8,0,0"/>
                        <TextBlock Text="Tổng số khách hàng" Foreground="{StaticResource Muted}" FontSize="11.5" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Revenue chart -->
            <Border Style="{StaticResource CardBorder}" Padding="22" Margin="0,16,0,22">
                <StackPanel>
                    <DockPanel LastChildFill="False">
                        <TextBlock DockPanel.Dock="Left" Text="Doanh thu 6 tháng gần nhất" FontSize="15" FontWeight="Bold"/>
                        <TextBlock DockPanel.Dock="Right" Text="{Binding ProfitText, StringFormat='Lợi nhuận ước tính: {0}'}" Foreground="{StaticResource Success}" FontSize="12.5" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </DockPanel>
                    <ItemsControl ItemsSource="{Binding MonthlyRevenue}" Height="210" Margin="0,18,0,0">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Rows="1"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="10,0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Text="{Binding ValueText}" Foreground="{StaticResource Muted}" FontSize="11" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                                    <Border Grid.Row="1" VerticalAlignment="Bottom" Height="{Binding BarHeight}" CornerRadius="6,6,0,0">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                <GradientStop Color="#3B82F6" Offset="0"/>
                                                <GradientStop Color="#2563EB" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                    </Border>
                                    <TextBlock Grid.Row="2" Text="{Binding Label}" Foreground="{StaticResource Muted}" FontSize="12" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <TextBlock Text="Chức năng chính" FontWeight="Bold" FontSize="16" Margin="2,0,0,14"/>
            <UniformGrid Columns="3">
                <Button Command="{Binding OpenNhanVienCommand}" Style="{StaticResource TileButton}" Visibility="{Binding CanManageEmployees, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <TextBlock Text="👤" FontSize="22"/>
                        <TextBlock Text="Danh sách nhân viên" FontSize="15" FontWeight="Bold" Margin="0,8,0,0"/>
                        <TextBlock Text="Quản lý hồ sơ, công việc và liên hệ." TextWrapping="Wrap" Foreground="{StaticResource Muted}" FontSize="12.5" Margin="0,4,0,0"/>
                    </StackPanel>
                </Button>
                <Button Command="{Binding OpenKhachHangCommand}" Style="{StaticResource TileButton}" Visibility="{Binding CanManageCustomers, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <TextBlock Text="👥" FontSize="22"/>
                        <TextBlock Text="Danh sách khách hàng" FontSize="15" FontWeight="Bold" Margin="0,8,0,0"/>
                        <TextBlock Text="Thông tin khách phục vụ bán hàng và tra cứu." TextWrapping="Wrap" Foreground="{StaticResource Muted}" FontSize="12.5" Margin="0,4,0,0"/>
                    </StackPanel>
                </Button>
                <Button Command="{Binding OpenHangHoaCommand}" Style="{StaticResource TileButton}" Visibility="{Binding CanManageProducts, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <TextBlock Text="🏍" FontSize="22"/>
                        <TextBlock Text="Danh sách xe máy" FontSize="15" FontWeight="Bold" Margin="0,8,0,0"/>
                        <TextBlock Text="Thông số xe, tồn kho, giá nhập và giá bán." TextWrapping="Wrap" Foreground="{StaticResource Muted}" FontSize="12.5" Margin="0,4,0,0"/>
                    </StackPanel>
                </Button>
                <Button Command="{Binding OpenTimHangCommand}" Style="{StaticResource TileButton}" Visibility="{Binding CanSearch, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <TextBlock Text="🔍" FontSize="22"/>
                        <TextBlock Text="Tìm kiếm dữ liệu" FontSize="15" FontWeight="Bold" Margin="0,8,0,0"/>
                        <TextBlock Text="Tìm xe, khách hàng, hóa đơn nhập và đơn bán." TextWrapping="Wrap" Foreground="{StaticResource Muted}" FontSize="12.5" Margin="0,4,0,0"/>
                    </StackPanel>
                </Button>
                <Button Command="{Binding OpenBaoCaoNhapCommand}" Style="{StaticResource TileButton}" Visibility="{Binding CanReports, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <TextBlock Text="📥" FontSize="22"/>
                        <TextBlock Text="Báo cáo nhập hàng" FontSize="15" FontWeight="Bold" Margin="0,8,0,0"/>
                        <TextBlock Text="Theo dõi nguồn hàng, chi phí và nhà cung cấp." TextWrapping="Wrap" Foreground="{StaticResource Muted}" FontSize="12.5" Margin="0,4,0,0"/>
                    </StackPanel>
                </Button>
                <Button Command="{Binding OpenBaoCaoKQKDCommand}" Style="{StaticResource TileButton}" Visibility="{Binding CanReports, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <TextBlock Text="📈" FontSize="22"/>
                        <TextBlock Text="Thông tin doanh thu" FontSize="15" FontWeight="Bold" Margin="0,8,0,0"/>
                        <TextBlock Text="Tổng hợp doanh thu, tiền cọc, thuế và lợi nhuận." TextWrapping="Wrap" Foreground="{StaticResource Muted}" FontSize="12.5" Margin="0,4,0,0"/>
                    </StackPanel>
                </Button>
            </UniformGrid>

            <Border Style="{StaticResource CardBorder}" Padding="20" Margin="0,4,0,0">
                <StackPanel>
                    <TextBlock Text="Danh mục nhanh" FontSize="15" FontWeight="Bold"/>
                    <WrapPanel Margin="0,14,0,-8">
                        <Button Content="Công việc" Command="{Binding OpenCongViecCommand}" Style="{StaticResource ChipButton}" Visibility="{Binding CanManageEmployees, Converter={StaticResource BoolToVis}}"/>
                        <Button Content="Nhà cung cấp" Command="{Binding OpenNhaCungCapCommand}" Style="{StaticResource ChipButton}" Visibility="{Binding CanManageSuppliers, Converter={StaticResource BoolToVis}}"/>
                        <Button Content="Thể loại" Command="{Binding OpenTheLoaiCommand}" Style="{StaticResource ChipButton}" Visibility="{Binding CanManageProducts, Converter={StaticResource BoolToVis}}"/>
                        <Button Content="Màu sắc" Command="{Binding OpenMauSacCommand}" Style="{StaticResource ChipButton}" Visibility="{Binding CanManageProducts, Converter={StaticResource BoolToVis}}"/>
                        <Button Content="Hãng sản xuất" Command="{Binding OpenHangSXCommand}" Style="{StaticResource ChipButton}" Visibility="{Binding CanManageProducts, Converter={StaticResource BoolToVis}}"/>
                        <Button Content="Nước sản xuất" Command="{Binding OpenNuocSXCommand}" Style="{StaticResource ChipButton}" Visibility="{Binding CanManageProducts, Converter={StaticResource BoolToVis}}"/>
                        <Button Content="Phanh xe" Command="{Binding OpenPhanhCommand}" Style="{StaticResource ChipButton}" Visibility="{Binding CanManageProducts, Converter={StaticResource BoolToVis}}"/>
                        <Button Content="Động cơ" Command="{Binding OpenDongCoCommand}" Style="{StaticResource ChipButton}" Visibility="{Binding CanManageProducts, Converter={StaticResource BoolToVis}}"/>
                        <Button Content="Tình trạng" Command="{Binding OpenTinhTrangCommand}" Style="{StaticResource ChipButton}" Visibility="{Binding CanManageProducts, Converter={StaticResource BoolToVis}}"/>
                        <Button Content="Top sản phẩm" Command="{Binding OpenBaoCaoTopCommand}" Style="{StaticResource ChipButton}" Visibility="{Binding CanReports, Converter={StaticResource BoolToVis}}"/>
                        <Button Content="Quản trị tài khoản" Command="{Binding OpenUserAdminCommand}" Style="{StaticResource ChipButton}" Visibility="{Binding CanUserAdmin, Converter={StaticResource BoolToVis}}"/>
                        <Button Content="Nhật ký hệ thống" Command="{Binding OpenAuditLogCommand}" Style="{StaticResource ChipButton}" Visibility="{Binding CanAuditLog, Converter={StaticResource BoolToVis}}"/>
                    </WrapPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
